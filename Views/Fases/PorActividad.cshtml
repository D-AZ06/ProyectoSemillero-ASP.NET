@model IEnumerable<ProyectoSemillero_ASP.NET.Models.Fase>

@{
    ViewBag.Title = "Fases de la Actividad";
    Layout = "~/Views/Shared/_LayoutSimple.cshtml";

    string rolActual = Session["Rol"] != null ? Session["Rol"].ToString() : "";

    int idProyecto = ViewBag.IdProyecto;
    string tituloProyecto = ViewBag.TituloProyecto;
    int idActividad = ViewBag.IdActividad;
    string nombreActividad = ViewBag.NombreActividad;
    bool desdeGlobal = ViewBag.DesdeGlobal != null ? (bool)ViewBag.DesdeGlobal : false;
}

<style>
    body > .container {
        display: block !important;
        padding-top: 2rem !important;
    }
</style>

<div class="w-100 text-start mb-5">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h3 class="fw-bold text-dark mb-0">
            <i class="bi bi-diagram-3-fill text-primary me-2"></i> Fases de la Actividad
        </h3>

        <div class="d-flex gap-2">
            @if (desdeGlobal)
            {
                <a href="@Url.Action("Index", "Actividades")" class="btn btn-outline-secondary fw-bold shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver a Actividades Globales
                </a>
            }
            else
            {
                <a href="@Url.Action("PorProyecto", "Actividades", new { idProyecto = idProyecto })" class="btn btn-outline-secondary fw-bold shadow-sm">
                    <i class="bi bi-arrow-left"></i> Volver a Actividades del Proyecto
                </a>
            }

            @if (rolActual != "Investigador")
            {
                <a href="@Url.Action("Agregar", "Fases", new { idProyecto = idProyecto, idActividad = idActividad, desdeGlobal = desdeGlobal })" class="btn btn-success fw-bold shadow-sm">
                    <i class="bi bi-plus-circle me-1"></i> Agregar Fase
                </a>
            }
        </div>
    </div>

    <div class="card border-start border-4 border-info shadow-sm mb-4 bg-white">
        <div class="card-body py-3">
            <div class="row align-items-center">
                <div class="col-auto border-end pe-3">
                    <span class="badge bg-secondary p-2 fs-6 text-white fw-bold mb-1" style="border-radius: 8px;">Proyecto ID: @idProyecto</span><br />
                    <small class="text-muted fw-bold">@tituloProyecto</small>
                </div>
                <div class="col ps-3">
                    <span class="badge bg-info p-2 fs-6 text-white fw-bold mb-1" style="border-radius: 8px;">Actividad ID: @idActividad</span><br />
                    <h5 class="text-secondary mb-0 fw-bold">Título: <span class="text-dark">@nombreActividad</span></h5>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded-3 border bg-white">
        <table class="table table-hover table-striped mb-0 align-middle">
            <thead class="table-dark">
                <tr>
                    <th scope="col" class="py-3 ps-4" style="width: 100px;">ID Fase</th>
                    <th scope="col" class="py-3">Nombre de la Fase</th>
                    <th scope="col" class="py-3" style="width: 200px;">Duración</th>
                    <th scope="col" class="py-3 text-center" style="width: 150px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var fase in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-secondary">@fase.IdFase</td>
                            <td>
                                <span class="text-dark fw-bold">@fase.NombreFase</span>
                            </td>
                            <td>
                                <span class="text-secondary"><i class="bi bi-clock-history me-2"></i>@fase.DuracionFase</span>
                            </td>
                            <td class="text-center">
                                @if (rolActual != "Investigador")
                                {
                                    <a href="@Url.Action("Modificar", "Fases", new { idProyecto = idProyecto, idActividad = idActividad, idFase = fase.IdFase, vinoDesdePorActividad = true, desdeGlobal = desdeGlobal })" class="btn btn-sm btn-outline-primary me-1" title="Modificar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger" title="Eliminar" onclick="confirmarEliminacion(@idProyecto, @idActividad, @fase.IdFase, @desdeGlobal.ToString().ToLower())">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" disabled title="Solo lectura"><i class="bi bi-eye"></i></button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            Esta actividad no cuenta con fases registradas actualmente.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

@section Scripts {
    <script>
        var mensajeExito = '@TempData["Exito"]';
        if (mensajeExito && mensajeExito !== '') {
            Swal.fire({ icon: 'success', title: '¡Operación Exitosa!', text: mensajeExito, confirmButtonColor: '#0284c7' });
        }
        var mensajeError = '@TempData["Error"]';
        if (mensajeError && mensajeError !== '') {
            Swal.fire({ icon: 'error', title: 'Oops...', text: mensajeError, confirmButtonColor: '#dc3545' });
        }

        function confirmarEliminacion(idProyecto, idActividad, idFase, desdeGlobal) {
            Swal.fire({
                title: '¿Estás seguro?',
                text: "Esta acción borrará la fase permanentemente.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    // AQUÍ ESTÁ EL CAMBIO
                    window.location.href = '@Url.Action("Eliminar", "Fases")?idProyecto=' + idProyecto + '&idActividad=' + idActividad + '&idFase=' + idFase + '&vinoDesdePorActividad=true&desdeGlobal=' + desdeGlobal;
                }
            });
        }
    </script>
}