@model IEnumerable<ProyectoSemillero_ASP.NET.Models.DatosFase>

@{
    ViewBag.Title = "Gestionar Fases";

    string rolActual = "";
    if (Session["Rol"] != null)
    {
        rolActual = Session["Rol"].ToString();
    }
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <h3 class="fw-bold text-dark mb-0">
        <i class="bi bi-diagram-3 text-primary me-2"></i> Gestionar Fases
    </h3>

    @if (rolActual != "Investigador")
    {
        <a href="@Url.Action("Agregar", "Fases")" class="btn btn-success fw-bold shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Agregar Fase
        </a>
    }
</div>

<div class="card bg-light border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form action="@Url.Action("Index", "Fases")" method="get" id="formBusqueda">
            <div class="row g-2 align-items-center">
                <div class="col-12 col-md-auto">
                    <span class="fw-bold text-secondary mb-0"><i class="bi bi-funnel me-1"></i> Consultar por parámetros:</span>
                </div>

                <div class="col-12 col-md-3">
                    <select class="form-select border-info" id="selectFiltro" name="tipoFiltro">
                        <option value="">Seleccione filtro...</option>
                        <option value="idProyecto">ID Proyecto</option>
                        <option value="tituloProyecto">Título del Proyecto</option>
                        <option value="idActividad">ID Actividad</option>
                        <option value="nombreActividad">Nombre de la Actividad</option>
                        <option value="idFase">ID Fase</option>
                        <option value="nombreFase">Nombre de la Fase</option>
                    </select>
                </div>

                <div class="col-12 col-md" id="contenedorInput">
                    <input type="text" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="Seleccione un filtro primero..." disabled>
                </div>

                <datalist id="opcionesSugeridas"></datalist>

                <div class="col-12 col-md-auto">
                    <button type="submit" class="btn btn-info text-white fw-bold px-4 w-100" id="btnConsultar" disabled>
                        <i class="bi bi-search"></i> Consultar
                    </button>
                </div>

                @if (Request.QueryString["tipoFiltro"] != null)
                {
                    <div class="col-12 col-md-auto">
                        <a href="@Url.Action("Index", "Fases")" class="btn btn-secondary fw-bold w-100">
                            <i class="bi bi-arrow-clockwise"></i> Limpiar
                        </a>
                    </div>
                }
            </div>
        </form>
    </div>
</div>

<div class="table-responsive shadow-sm rounded-3 border">
    <table class="table table-hover table-striped mb-0 align-middle" id="tablaFases">
        <thead class="table-dark">
            <tr>
                <th scope="col" class="py-3 ps-3">ID Fase</th>
                <th scope="col" class="py-3">Nombre de Fase</th>
                <th scope="col" class="py-3">Duración</th>
                <th scope="col" class="py-3">Proyecto Correspondiente</th>
                <th scope="col" class="py-3">Actividad Correspondiente</th>
                <th scope="col" class="py-3 text-center" style="min-width: 120px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var fase in Model)
                {
                    <tr>
                        <td class="ps-3 fw-medium data-idFase">@fase.IdFase</td>

                        <td class="data-nombreFase" style="max-width: 180px; white-space: normal; word-wrap: break-word;">
                            <span class="text-dark fw-bold">@fase.NombreFase</span>
                        </td>

                        <td>@fase.DuracionFase</td>

                        <td style="max-width: 200px; white-space: normal; word-wrap: break-word;">
                            <span class="badge bg-secondary mb-1 data-idProyecto">ID: @fase.IdProyecto</span><br />
                            <small class="fw-bold text-success data-tituloProyecto">@fase.TituloProyecto</small>
                        </td>

                        <td style="max-width: 200px; white-space: normal; word-wrap: break-word;">
                            <span class="badge bg-secondary mb-1 data-idActividad">ID: @fase.IdActividad</span><br />
                            <small class="fw-bold text-primary data-nombreActividad">@fase.NombreActividad</small>
                        </td>

                        <td class="text-center">
                            @if (rolActual != "Investigador")
                            {
                                <a href="@Url.Action("Modificar", "Fases", new { idProyecto = fase.IdProyecto, idActividad = fase.IdActividad, idFase = fase.IdFase, vinoDesdePorActividad = false })" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmarEliminacion(@fase.IdProyecto, @fase.IdActividad, @fase.IdFase)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary" disabled title="Solo lectura">
                                    <i class="bi bi-eye"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">
                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                        No se encontraron fases registradas o que coincidan con la búsqueda.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        const datosAutocompletado = {
            idProyecto: [...new Set(Array.from(document.querySelectorAll('.data-idProyecto')).map(el => el.textContent.replace('ID: ', '').trim()))],
            tituloProyecto: [...new Set(Array.from(document.querySelectorAll('.data-tituloProyecto')).map(el => el.textContent.trim()))],
            idActividad: [...new Set(Array.from(document.querySelectorAll('.data-idActividad')).map(el => el.textContent.replace('ID: ', '').trim()))],
            nombreActividad: [...new Set(Array.from(document.querySelectorAll('.data-nombreActividad')).map(el => el.textContent.trim()))],
            idFase: [...new Set(Array.from(document.querySelectorAll('.data-idFase')).map(el => el.textContent.trim()))],
            nombreFase: [...new Set(Array.from(document.querySelectorAll('.data-nombreFase')).map(el => el.textContent.trim()))]
        };

        const selectFiltro = document.getElementById('selectFiltro');
        const contenedorInput = document.getElementById('contenedorInput');
        const btnConsultar = document.getElementById('btnConsultar');
        const datalist = document.getElementById('opcionesSugeridas');

        selectFiltro.addEventListener('change', function () {
            const filtroSeleccionado = this.value;
            datalist.innerHTML = '';

            if (!filtroSeleccionado) {
                contenedorInput.innerHTML = '<input type="text" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="Seleccione un filtro primero..." disabled>';
                btnConsultar.disabled = true;
                return;
            }

            btnConsultar.disabled = false;
            let esNumero = (filtroSeleccionado === 'idProyecto' || filtroSeleccionado === 'idActividad' || filtroSeleccionado === 'idFase');
            let tipoInput = esNumero ? 'number' : 'text';
            let placeholder = esNumero ? 'Seleccione o ingrese un ID...' : 'Escriba para buscar sugerencias...';
            let extraAttr = esNumero ? 'min="1"' : '';

            let nuevoInput = `<input type="${tipoInput}" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="${placeholder}" ${extraAttr} list="opcionesSugeridas" autocomplete="off" required>`;

            if (datosAutocompletado[filtroSeleccionado]) {
                datosAutocompletado[filtroSeleccionado].forEach(valor => {
                    let option = document.createElement('option');
                    option.value = valor;
                    datalist.appendChild(option);
                });
            }

            contenedorInput.innerHTML = nuevoInput;
            configurarValidacionEnTiempoReal();
        });

        function configurarValidacionEnTiempoReal() {
            const inputValor = document.getElementById('inputValor');
            const formBusqueda = document.getElementById('formBusqueda');

            formBusqueda.addEventListener('submit', function (e) {
                const filtro = selectFiltro.value;
                const valor = inputValor.value.trim();

                if (!valor) {
                    e.preventDefault();
                    Swal.fire({ icon: 'warning', title: 'Campo requerido', text: 'Por favor ingrese un valor para buscar.', confirmButtonColor: '#0284c7' });
                    return;
                }

                if (['idProyecto', 'tituloProyecto', 'idActividad', 'nombreActividad', 'idFase', 'nombreFase'].includes(filtro)) {
                    if (!datosAutocompletado[filtro].includes(valor)) {
                        e.preventDefault();
                        Swal.fire({ icon: 'error', title: 'Dato no válido', text: 'El valor ingresado no coincide con ningún registro existente en pantalla.', confirmButtonColor: '#dc3545' });
                    }
                }
            });
        }

        var mensajeExito = '@TempData["Exito"]';
        if (mensajeExito && mensajeExito !== '') {
            Swal.fire({ icon: 'success', title: '¡Operación Exitosa!', text: mensajeExito, confirmButtonColor: '#0284c7' });
        }
        var mensajeError = '@TempData["Error"]';
        if (mensajeError && mensajeError !== '') {
            Swal.fire({ icon: 'error', title: 'Oops...', text: mensajeError, confirmButtonColor: '#dc3545' });
        }

        function confirmarEliminacion(idProyecto, idActividad, idFase) {
            Swal.fire({
                title: '¿Estás seguro?',
                text: "Esta acción borrará la fase permanentemente.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    // AQUÍ ESTÁ EL CAMBIO
                    window.location.href = '@Url.Action("Eliminar", "Fases")?idProyecto=' + idProyecto + '&idActividad=' + idActividad + '&idFase=' + idFase + '&vinoDesdePorActividad=false';
                }
            });
        }
    </script>
}