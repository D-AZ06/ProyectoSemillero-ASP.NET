@model IEnumerable<ProyectoSemillero_ASP.NET.Models.DatosReunion>

@{
    ViewBag.Title = "Gestionar Reuniones";
    string rolActual = Session["Rol"] != null ? Session["Rol"].ToString() : "";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <h3 class="fw-bold text-dark mb-0">
        <i class="bi bi-calendar-event text-primary me-2"></i> Gestión de Reuniones
    </h3>

    @if (rolActual == "Administrador" || rolActual == "Admin" || rolActual == "Líder")
    {
        <a href="@Url.Action("Agregar", "Reuniones")" class="btn btn-success fw-bold shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Agendar Reunión
        </a>
    }
</div>

<div class="card bg-light border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form action="@Url.Action("Index", "Reuniones")" method="get" id="formBusqueda">
            <div class="row g-2 align-items-center">
                <div class="col-12 col-md-auto">
                    <span class="fw-bold text-secondary mb-0"><i class="bi bi-funnel me-1"></i> Consultar por parámetros:</span>
                </div>

                <div class="col-12 col-md-3">
                    <select class="form-select border-info" id="selectFiltro" name="tipoFiltro">
                        <option value="">Seleccione filtro...</option>
                        <option value="idReunion">ID Reunión</option>
                        <option value="fechaReunion">Fecha de Reunión</option>
                        <option value="mesReunion">Mes de Reunión</option>
                        <option value="horaInicio">Hora de Inicio</option>
                        <option value="horaFin">Hora de Fin</option>
                        <option value="motivoReunion">Motivo de Reunión</option>
                        <option value="lugarReunion">Lugar de Reunión</option>
                        <option value="estadoReunion">Estado</option>
                    </select>
                </div>

                <div class="col-12 col-md" id="contenedorInput">
                    <input type="text" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="Seleccione un filtro primero..." disabled>
                </div>

                <datalist id="opcionesSugeridas"></datalist>

                <div class="col-12 col-md-auto">
                    <button type="submit" class="btn btn-info text-white fw-bold px-4 w-100" id="btnConsultar" disabled>
                        <i class="bi bi-search"></i> Consultar
                    </button>
                </div>

                @if (Request.QueryString["tipoFiltro"] != null)
                {
                    <div class="col-12 col-md-auto">
                        <a href="@Url.Action("Index", "Reuniones")" class="btn btn-secondary fw-bold w-100">
                            <i class="bi bi-arrow-clockwise"></i> Limpiar
                        </a>
                    </div>
                }
            </div>
        </form>
    </div>
</div>

<div class="table-responsive shadow-sm rounded-3 border">
    <table class="table table-hover table-striped mb-0 align-middle">
        <thead class="table-dark">
            <tr>
                <th scope="col" class="py-3 ps-3">ID</th>
                <th scope="col" class="py-3">Fecha y Horario</th>
                <th scope="col" class="py-3">Lugar</th>
                <th scope="col" class="py-3">Estado</th>
                <th scope="col" class="py-3 text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var r in Model)
                {
                    bool estadoValido = (r.EstadoReunion == "Programada" || r.EstadoReunion == "Reprogramado");
                    bool tieneAsistencias = r.InvestigadoresConvocados != null && r.InvestigadoresConvocados.Any(i => i.EstadoAsistencia == "Confirmado");

                    bool faltanMenosDe2Horas = false;
                    if (DateTime.TryParse(r.FechaReunion + " " + r.HoraInicio, out DateTime fechaHoraInicio))
                    {
                        double diffHoras = (fechaHoraInicio - DateTime.Now).TotalHours;
                        if (diffHoras >= 0 && diffHoras < 2)
                        {
                            faltanMenosDe2Horas = true;
                        }
                    }

                    bool puedeModificar = estadoValido && !tieneAsistencias && !faltanMenosDe2Horas;
                    bool puedeCancelar = estadoValido;

                    <tr>
                        <td class="ps-3 fw-medium">
                            <span class="data-idReunion">@r.IdReunion</span>
                            <span class="data-motivoReunion d-none">@r.MotivoReunion</span>
                            <span class="data-idLider d-none">@r.IdLider</span>
                        </td>
                        <td class="fw-bold text-primary">
                            <i class="bi bi-calendar3"></i> <span class="data-fechaReunion">@r.FechaReunion</span> <br />
                            <small class="text-dark"><i class="bi bi-clock"></i> <span class="data-horaInicio">@r.HoraInicio</span> - @r.HoraFin</small>
                        </td>
                        <td class="data-lugarReunion">@r.LugarReunion</td>
                        <td>
                            @if (r.EstadoReunion == "Cancelado")
                            {<span class="badge bg-danger data-estadoReunion">@r.EstadoReunion</span> }
                        else if (r.EstadoReunion == "Finalizada")
                        { <span class="badge bg-success data-estadoReunion">@r.EstadoReunion</span> }
                    else
                    { <span class="badge bg-info text-dark data-estadoReunion">@r.EstadoReunion</span>}
                        </td>

                        <td class="text-center">
                            <div class="btn-group shadow-sm">
                                @if (puedeModificar)
                                {
                                    <a href="@Url.Action("Modificar", "Reuniones", new { id = r.IdReunion })" class="btn btn-sm btn-outline-primary" title="Modificar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" disabled title="Bloqueado por reglas de negocio"><i class="bi bi-lock-fill"></i></button>
                                }

                                @if (puedeCancelar)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-danger" title="Cancelar" onclick="confirmarCancelacion(@r.IdReunion)">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" disabled><i class="bi bi-slash-circle"></i></button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" class="text-center py-4 text-muted"><i class="bi bi-inbox fs-2 d-block mb-2"></i> No hay reuniones programadas.</td></tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // Mapeo de datos para autocompletado en base a las filas de la tabla
        const datosAutocompletado = {
            idReunion: [...new Set(Array.from(document.querySelectorAll('.data-idReunion')).map(el => el.textContent.trim()))],
            motivoReunion: [...new Set(Array.from(document.querySelectorAll('.data-motivoReunion')).map(el => el.textContent.trim()))],
            idLider: [...new Set(Array.from(document.querySelectorAll('.data-idLider')).map(el => el.textContent.trim()))],
            lugarReunion: [...new Set(Array.from(document.querySelectorAll('.data-lugarReunion')).map(el => el.textContent.trim()))],
            estadoReunion: [...new Set(Array.from(document.querySelectorAll('.data-estadoReunion')).map(el => el.textContent.trim()))]
        };

        const selectFiltro = document.getElementById('selectFiltro');
        const contenedorInput = document.getElementById('contenedorInput');
        const btnConsultar = document.getElementById('btnConsultar');
        const datalist = document.getElementById('opcionesSugeridas');

        selectFiltro.addEventListener('change', function () {
            const filtroSeleccionado = this.value;
            datalist.innerHTML = '';

            if (!filtroSeleccionado) {
                contenedorInput.innerHTML = '<input type="text" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="Seleccione un filtro primero..." disabled>';
                btnConsultar.disabled = true;
                return;
            }

            btnConsultar.disabled = false;
            let nuevoInput = '';

            if (filtroSeleccionado === 'fechaReunion') {
                nuevoInput = `<input type="date" class="form-control border-info" id="inputValor" name="valorFiltro" required>`;
            }
            else if (filtroSeleccionado === 'mesReunion') {
                nuevoInput = `<input type="month" class="form-control border-info" id="inputValor" name="valorFiltro" required>`;
            }
            else if (filtroSeleccionado === 'horaInicio') {
                nuevoInput = `<input type="time" class="form-control border-info" id="inputValor" name="valorFiltro" required>`;

            }
            else if (filtroSeleccionado === 'horaInicio' || filtroSeleccionado === 'horaFin') {
                nuevoInput = `<input type="time" class="form-control border-info" id="inputValor" name="valorFiltro" required>`;
            }

            // NUEVO FILTRO CORREGIDO: Expresión regular para que empiece obligatoriamente con 60
            else if (filtroSeleccionado === 'prefijo60') {
                nuevoInput = `<input type="text" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="Ej: 600, 609, 6010..." pattern="^60[0-9]+" title="El ID debe comenzar estrictamente con 60 (ejemplo: 600, 609, 6010)" required autocomplete="off">`;
            }
            else {
                let esNumero = (filtroSeleccionado === 'idReunion' || filtroSeleccionado === 'idLider');
                let tipoInput = esNumero ? 'number' : 'text';
                let placeholder = esNumero ? 'Seleccione o ingrese un ID...' : 'Escriba para buscar sugerencias...';
                let extraAttr = esNumero ? 'min="1"' : '';

                nuevoInput = `<input type="${tipoInput}" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="${placeholder}" ${extraAttr} list="opcionesSugeridas" autocomplete="off" required>`;

                if (datosAutocompletado[filtroSeleccionado]) {
                    datosAutocompletado[filtroSeleccionado].forEach(valor => {
                        let option = document.createElement('option');
                        option.value = valor;
                        datalist.appendChild(option);
                    });
                }
            }

            contenedorInput.innerHTML = nuevoInput;
            configurarValidacionEnTiempoReal();
        });

        function configurarValidacionEnTiempoReal() {
            const inputValor = document.getElementById('inputValor');
            const formBusqueda = document.getElementById('formBusqueda');

            formBusqueda.addEventListener('submit', function (e) {
                const filtro = selectFiltro.value;
                const valor = inputValor.value.trim();

                if (!valor) {
                    e.preventDefault();
                    Swal.fire({ icon: 'warning', title: 'Campo requerido', text: 'Por favor ingrese un valor para buscar.', confirmButtonColor: '#0284c7' });
                    return;
                }

                if (['idReunion', 'lugarReunion', 'estadoReunion', 'motivoReunion'].includes(filtro)) {
                    if (!datosAutocompletado[filtro].includes(valor)) {
                        e.preventDefault();
                        Swal.fire({ icon: 'error', title: 'Dato no válido', text: 'El valor ingresado no coincide con ningún registro existente.', confirmButtonColor: '#dc3545' });
                    }
                }

                // Validación en tiempo real para el botón de enviar en la secuencia 60
                if (filtro === 'prefijo60') {
                    const cumpleIdReunion = datosAutocompletado.idReunion.includes(valor);
                    const cumpleIdLider = datosAutocompletado.idLider.includes(valor);

                    if (!cumpleIdReunion && !cumpleIdLider) {
                        e.preventDefault();
                        Swal.fire({ icon: 'error', title: 'ID no encontrado', text: 'El ID con secuencia 60 ingresado no corresponde a ninguna Reunión ni Líder en el sistema.', confirmButtonColor: '#dc3545' });
                    }
                }
            });
        }

        function confirmarCancelacion(id) {
            Swal.fire({
                title: '¿Cancelar Reunión?',
                text: "Esta acción pasará el estado a 'Cancelado' y liberará el horario de los investigadores.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ffc107',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("CancelarReunion", "Reuniones")', { id: id }, function(res) {
                        if (res.success) {
                            window.location.reload();
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}