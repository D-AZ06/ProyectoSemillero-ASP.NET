@{
    ViewData["Title"] = "Bienvenido";
    Layout = "~/Views/Shared/_LayoutSimple.cshtml";
}

<div class="container d-flex flex-column justify-content-center align-items-center py-5" style="min-height: calc(100vh - 70px);">

    <!-- Contenedor Principal -->
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden w-100" style="max-width: 850px;">

        <!-- Cabecera de la tarjeta con gradiente -->
        <div class="p-5 text-center text-white" style="background: linear-gradient(135deg, #0284c7 0%, #004e75 100%); position: relative;">
            <!-- Efecto de fondo sutil -->
            <i class="bi bi-cpu" style="font-size: 15rem; position: absolute; right: -20px; top: -50px; opacity: 0.1;"></i>

            <div style="position: relative; z-index: 1;">
                <div class="d-inline-block p-3 bg-white bg-opacity-10 rounded-circle mb-3 border border-light border-opacity-25 shadow-sm">
                    <i class="bi bi-cpu display-4 text-white"></i>
                </div>
                <h1 class="display-5 fw-bold mb-2">GesSi</h1>
                <p class="fs-5 mb-0 opacity-75">Sistema de Gestión de Semilleros de Investigación</p>
            </div>
        </div>

        <!-- Cuerpo de la tarjeta -->
        <div class="card-body bg-white p-4 p-md-5">

            <div class="text-center mb-5">
                <h3 class="text-secondary fw-bold">¡Hola! Es un gusto tenerte aquí 👋</h3>
                <p class="text-muted fs-5">Estás a un paso de ingresar a tu entorno de trabajo centralizado.</p>
            </div>

            <!-- Sección de características (3 columnas) -->
            <div class="row g-4 mb-5">
                <div class="col-md-4 text-center px-3">
                    <div class="rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow-sm" style="width: 60px; height: 60px; background-color: #f0f9ff; color: #0284c7;">
                        <i class="bi bi-kanban fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Gestión Ágil</h5>
                    <p class="text-muted small mb-0">Administra tus proyectos, tareas y usuarios de forma intuitiva.</p>
                </div>

                <div class="col-md-4 text-center px-3 border-start border-end d-none d-md-block">
                    <div class="rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow-sm" style="width: 60px; height: 60px; background-color: #f0f9ff; color: #0284c7;">
                        <i class="bi bi-shield-check fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Entorno Seguro</h5>
                    <p class="text-muted small mb-0">Accede a tus módulos según tu rol con credenciales protegidas.</p>
                </div>

                <!-- En móviles, ocultamos los bordes laterales -->
                <div class="col-md-4 text-center px-3 d-block d-md-none">
                    <div class="rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow-sm" style="width: 60px; height: 60px; background-color: #f0f9ff; color: #0284c7;">
                        <i class="bi bi-shield-check fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Entorno Seguro</h5>
                    <p class="text-muted small mb-0">Accede a tus módulos según tu rol con credenciales protegidas.</p>
                </div>

                <div class="col-md-4 text-center px-3">
                    <div class="rounded-circle d-inline-flex justify-content-center align-items-center mb-3 shadow-sm" style="width: 60px; height: 60px; background-color: rgba(23, 162, 184, 0.1); color: #17a2b8;">
                        <i class="bi bi-robot fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Asistencia IA</h5>
                    <p class="text-muted small mb-0">Resuelve dudas al instante con nuestro asistente inteligente integrado.</p>
                </div>
            </div>

            <!-- Botón de acción -->
            <div class="text-center mt-2">
                <a href="@Url.Action("IniciarSesion", "Home")" class="btn btn-lg text-white px-5 py-3 rounded-pill shadow-sm" style="background-color: #0284c7; transition: transform 0.2s ease, box-shadow 0.2s ease;">
                    <i class="bi bi-box-arrow-in-right me-2"></i> Iniciar Sesión Ahora
                </a>
            </div>

        </div>
    </div>
</div>

<!-- Pequeño script para darle un efecto hover sutil al botón -->
@section Scripts {
    <style>
        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
            background-color: #016a9f !important;
        }
    </style>
}