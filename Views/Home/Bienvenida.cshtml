@{
    // ESTA ES LA CLAVE: Desactiva el _Layout.cshtml maestro por completo
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bienvenido - GesSi</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

    <style>
        body {
            background-color: #f4f7f6; /* Fondo gris claro de oficina */
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding-top: 70px; /* Espacio para la barra superior */
        }

        /* Barra superior idéntica al layout, pero vacía (solo el logo) */
        .top-navbar-login {
            height: 70px;
            background-color: white;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1050;
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
        }
    </style>
</head>
<body>

    <header class="top-navbar-login">
        <div class="fs-4 fw-bold text-info m-0 d-flex align-items-center gap-2">
            <i class="bi bi-cpu"></i>
            <span class="text-dark">GesSi</span>
        </div>
    </header>

    <div class="container d-flex flex-column justify-content-center align-items-center" style="min-height: calc(100vh - 70px);">

        <div class="text-center p-5 rounded shadow-sm bg-white" style="border-top: 5px solid #0284c7; max-width: 600px; width: 100%;">

            <i class="bi bi-cpu display-1 text-info mb-3"></i>

            <h1 class="text-secondary fw-bold mb-3">Bienvenido a GesSi</h1>

            <p class="text-muted mb-4 fs-5">
                Sistema de Gestión Integrado. Por favor, inicie sesión con sus credenciales para acceder a su panel de control y opciones correspondientes a su rol.
            </p>

            <a href="@Url.Action("IniciarSesion", "Home")" class="btn btn-lg text-white shadow-sm" style="background-color: #0284c7; padding: 12px 40px; border-radius: 8px;">
                <i class="bi bi-box-arrow-in-right me-2"></i> Iniciar Sesión
            </a>

        </div>
    </div>

</body>
</html>