@model ProyectoSemillero_ASP.NET.Models.ValidarInicioSesion
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "~/Views/Shared/_LayoutSimple.cshtml";
}

@* ══════════════════════════════════════════════
    ESTILOS DEL YETI
    ══════════════════════════════════════════════ *@
<style>
    .yeti-page {
        min-height: calc(100vh - 70px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #f0f4f8;
        padding: 2rem 1rem;
    }

    .yeti-card {
        background: #fff;
        border-radius: 16px;
        border-top: 5px solid #0284c7;
        padding: 2rem 2.25rem 1.75rem;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.10);
    }

    .svgContainer {
        display: flex;
        justify-content: center;
        margin-bottom: 0.5rem;
    }

    .mySVG {
        width: 150px;
        height: 150px;
        overflow: visible;
    }

    .yeti-title {
        text-align: center;
        font-size: 1.35rem;
        font-weight: 700;
        color: #334155;
        margin-bottom: 4px;
    }

    .yeti-sub {
        text-align: center;
        font-size: 0.85rem;
        color: #94a3b8;
        margin-bottom: 1.5rem;
    }

    .yeti-label {
        display: block;
        font-size: 0.82rem;
        font-weight: 600;
        color: #475569;
        margin-bottom: 5px;
    }

    .yeti-input-wrap {
        display: flex;
        align-items: center;
        border: 1.5px solid #cbd5e1;
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 1rem;
        transition: border-color .2s;
        background: #fff;
    }

        .yeti-input-wrap:focus-within {
            border-color: #0284c7;
            box-shadow: 0 0 0 3px rgba(2,132,199,.12);
        }

        .yeti-input-wrap .icon, .yeti-input-wrap .eye-btn {
            padding: 0 12px;
            color: #94a3b8;
            font-size: 17px;
            display: flex;
            align-items: center;
        }

        .yeti-input-wrap input {
            flex: 1;
            border: none;
            outline: none;
            padding: 10px 4px;
            font-size: 14px;
            color: #1e293b;
            background: transparent;
        }

        .yeti-input-wrap .eye-btn {
            background: none;
            border: none;
            cursor: pointer;
        }

            .yeti-input-wrap .eye-btn:hover {
                color: #0284c7;
            }

    .yeti-btn-row {
        display: flex;
        gap: 10px;
        margin-top: 0.5rem;
    }

    .btn-yeti-cancel, .btn-yeti-submit {
        flex: 1;
        padding: 11px;
        font-size: 14px;
        border-radius: 10px;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        text-decoration: none;
    }

    .btn-yeti-cancel {
        border: 1.5px solid #e2e8f0;
        background: #f8fafc;
        color: #64748b;
    }

        .btn-yeti-cancel:hover {
            background: #e2e8f0;
            color: #334155;
        }

    .btn-yeti-submit {
        border: none;
        background: #0284c7;
        color: #fff;
        font-weight: 600;
        cursor: pointer;
    }

        .btn-yeti-submit:hover {
            background: #0369a1;
        }

    /* ── ANIMACIONES DEFINITIVAS DE LOS BRAZOS ── */
    .eyeL, .eyeR {
        transition: transform .1s ease-out;
    }

    .yeti-arm {
        transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        transform-origin: center bottom;
    }

    /* Estado 1: Escondidos abajo */
    .arms-hidden #armL_g, .arms-hidden #armR_g {
        transform: translateY(60px);
    }

    /* Estado 2: Tapando los ojos (Más al centro y un poquito más arriba) */
    .arms-covering #armL_g {
        transform: translate(28px, 1px);
    }

    .arms-covering #armR_g {
        transform: translate(-28px, 1px);
    }

    /* Estado 3: Espiando (Derecho fijo tapando, izquierdo baja para asomarse) */
    .arms-peeking #armL_g {
        transform: translate(10px, 25px) rotate(-10deg);
    }

    .arms-peeking #armR_g {
        transform: translate(-28px, 1px);
    }
</style>

<div class="yeti-page">
    <div class="yeti-card">

        @* ═══════════ SVG DEL YETI ═══════════ *@
        <div class="svgContainer">
            <svg class="mySVG" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
                <defs>
                    <clipPath id="circleMask">
                        <circle cx="100" cy="100" r="100" />
                    </clipPath>
                </defs>

                <g clip-path="url(#circleMask)">
                    <circle cx="100" cy="100" r="100" fill="#a9ddf3" />

                    <path stroke="#3A5E77" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="#FFFFFF"
                          d="M200,158.5c0-20.2-14.8-36.5-35-36.5h-14.9V72.8c0-27.4-21.7-50.4-49.1-50.8c-28-0.5-50.9,22.1-50.9,50v50H35.8C16,122,0,138,0,157.8L0,213h200L200,158.5z" />
                    <path fill="#DDF1FA" d="M100,156.4c-22.9,0-43,11.1-54.1,27.7c15.6,10,34.2,15.9,54.1,15.9s38.5-5.8,54.1-15.9C143,167.5,122.9,156.4,100,156.4z" />

                    <g fill="#ddf1fa" stroke="#3a5e77" stroke-width="2.5">
                        <circle cx="47" cy="83" r="11.5" />
                        <path d="M46.3 78.9c-2.3 0-4.1 1.9-4.1 4.1 0 2.3 1.9 4.1 4.1 4.1" stroke-linecap="round" stroke-linejoin="round" />
                        <circle cx="153" cy="83" r="11.5" />
                        <path d="M153.7,78.9c2.3,0,4.1,1.9,4.1,4.1c0,2.3-1.9,4.1-4.1,4.1" stroke-linecap="round" stroke-linejoin="round" />
                    </g>

                    <path fill="#DDF1FA" d="M134.5,46v35.5c0,21.815-15.446,39.5-34.5,39.5S65.5,103.315,65.5,81.5V46" />
                    <path fill="#FFFFFF" stroke="#3A5E77" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                          d="M81.457,27.929c1.755-4.084,5.51-8.262,11.253-11.77c0.979,2.565,1.883,5.14,2.712,7.723c3.162-4.265,8.626-8.27,16.272-11.235c-0.737,3.293-1.588,6.573-2.554,9.837c4.857-2.116,11.049-3.64,18.428-4.156c-2.403,3.23-5.021,6.391-7.852,9.474" />

                    <g class="eyeL"><circle cx="85.5" cy="78.5" r="3.5" fill="#3a5e77" /><circle cx="84" cy="76" r="1" fill="#fff" /></g>
                    <g class="eyeR"><circle cx="114.5" cy="78.5" r="3.5" fill="#3a5e77" /><circle cx="113" cy="76" r="1" fill="#fff" /></g>

                    <g class="mouth">
                        <path class="mouthBG" fill="#617E92" d="M100.2,101c-0.4,0-1.4,0-1.8,0c-2.7-0.3-5.3-1.1-8-2.5c-0.7-0.3-0.9-1.2-0.6-1.8c0.2-0.5,0.7-0.7,1.2-0.7c0.2,0,0.5,0.1,0.6,0.2c3,1.5,5.8,2.3,8.6,2.3s5.7-0.7,8.6-2.3c0.2-0.1,0.4-0.2,0.6-0.2c0.5,0,1,0.3,1.2,0.7c0.4,0.7,0.1,1.5-0.6,1.9c-2.6,1.4-5.3,2.2-7.9,2.5C101.7,101,100.5,101,100.2,101z" />
                        <path style="display:none" class="mouthSmallBG" fill="#617E92" stroke="#3A5E77" stroke-width="2.5" d="M100.2,101c-0.4,0-1.4,0-1.8,0c-2.7-0.3-5.3-1.1-8-2.5c-0.7-0.3-0.9-1.2-0.6-1.8c0.2-0.5,0.7-0.7,1.2-0.7c0.2,0,0.5,0.1,0.6,0.2c3,1.5,5.8,2.3,8.6,2.3s5.7-0.7,8.6-2.3c0.2-0.1,0.4-0.2,0.6-0.2c0.5,0,1,0.3,1.2,0.7c0.4,0.7,0.1,1.5-0.6,1.9c-2.6,1.4-5.3,2.2-7.9,2.5C101.7,101,100.5,101,100.2,101z" />
                        <path style="display:none" class="mouthMediumBG" fill="#617E92" stroke="#3A5E77" stroke-width="2.5" d="M95,104.2c-4.5,0-8.2-3.7-8.2-8.2v-2c0-1.2,1-2.2,2.2-2.2h22c1.2,0,2.2,1,2.2,2.2v2c0,4.5-3.7,8.2-8.2,8.2H95z" />
                        <path style="display:none" class="mouthLargeBG" fill="#617e92" stroke="#3a5e77" stroke-width="2.5" d="M100 110.2c-9 0-16.2-7.3-16.2-16.2 0-2.3 1.9-4.2 4.2-4.2h24c2.3 0 4.2 1.9 4.2 4.2 0 9-7.2 16.2-16.2 16.2z" />
                        <path class="mouthOutline" fill="none" stroke="#3A5E77" stroke-width="2.5" d="M100.2,101c-0.4,0-1.4,0-1.8,0c-2.7-0.3-5.3-1.1-8-2.5c-0.7-0.3-0.9-1.2-0.6-1.8c0.2-0.5,0.7-0.7,1.2-0.7c0.2,0,0.5,0.1,0.6,0.2c3,1.5,5.8,2.3,8.6,2.3s5.7-0.7,8.6-2.3c0.2-0.1,0.4-0.2,0.6-0.2c0.5,0,1,0.3,1.2,0.7c0.4,0.7,0.1,1.5-0.6,1.9c-2.6,1.4-5.3,2.2-7.9,2.5C101.7,101,100.5,101,100.2,101z" />
                    </g>

                    <path class="nose" fill="#3a5e77" d="M97.7 79.9h4.7c1.9 0 3 2.2 1.9 3.7l-2.3 3.3c-.9 1.3-2.9 1.3-3.8 0l-2.3-3.3c-1.3-1.6-.2-3.7 1.8-3.7z" />

                    @* ── BRAZOS ── *@
                    <g id="yeti-arms-group" class="arms-hidden">
                        <g id="armL_g" class="yeti-arm">
                            <path fill="#FFFFFF" stroke="#3A5E77" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                                  d="M -40,170 C -10,110 45,85 75,85 C 60,65 35,65 25,75 C 32,55 55,50 68,60 C 50,45 20,55 10,65 C 18,35 45,35 55,48 C 30,20 -10,30 -40,70" />
                        </g>
                        <g id="armR_g" class="yeti-arm">
                            <path fill="#FFFFFF" stroke="#3A5E77" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                                  d="M 240,170 C 210,110 155,85 125,85 C 140,65 165,65 175,75 C 168,55 145,50 132,60 C 150,45 180,55 190,65 C 182,35 155,35 145,48 C 170,20 210,30 240,70" />
                        </g>
                    </g>
                </g>
            </svg>
        </div>

        <h2 class="yeti-title">Iniciar Sesión</h2>
        <p class="yeti-sub">Ingrese sus credenciales de acceso</p>

        @* ═══════════ FORMULARIO ═══════════ *@
        @using (Html.BeginForm("IniciarSesion", "Home", FormMethod.Post, new { id = "form-login" }))
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger rounded" })

            <label class="yeti-label" for="Correo">Correo Electrónico</label>
            <div class="yeti-input-wrap">
                <span class="icon"><i class="bi bi-envelope"></i></span>
                @Html.TextBoxFor(m => m.Correo, new { id = "loginEmail", placeholder = "ejemplo@correo.com", autocomplete = "email", maxlength = "254" })
            </div>

            <label class="yeti-label" for="Contrasena">Contraseña</label>
            <div class="yeti-input-wrap">
                <span class="icon"><i class="bi bi-lock"></i></span>
                @Html.PasswordFor(m => m.Contrasena, new { id = "loginPassword", placeholder = "••••••••" })
                <button type="button" class="eye-btn" id="togglePass" aria-label="Mostrar contraseña">
                    <i class="bi bi-eye" id="eyeIcon"></i>
                </button>
            </div>

            <div class="yeti-btn-row">
                <a href="@Url.Action("Bienvenida", "Home")" class="btn-yeti-cancel"><i class="bi bi-arrow-left-circle"></i> Cancelar</a>
                <button type="submit" class="btn-yeti-submit"><i class="bi bi-box-arrow-in-right"></i> Ingresar</button>
            </div>
        }
    </div>
</div>

@* ══════════════════════════════════════════════
    SCRIPTS CONTROLADORES
    ══════════════════════════════════════════════ *@
<script>
document.addEventListener("DOMContentLoaded", function () {
    const eyeL = document.querySelector('.eyeL'), eyeR = document.querySelector('.eyeR');
    const mouthBG = document.querySelector('.mouthBG'), mouthSm = document.querySelector('.mouthSmallBG');
    const mouthMed = document.querySelector('.mouthMediumBG'), mouthLg = document.querySelector('.mouthLargeBG'), mouthOut = document.querySelector('.mouthOutline');
    const armsGroup = document.getElementById('yeti-arms-group');
    const emailInput = document.getElementById('loginEmail'), passwordInput = document.getElementById('loginPassword');
    const togglePass = document.getElementById('togglePass'), eyeIcon = document.getElementById('eyeIcon');

    // Manejo robusto de clases SVG (SOLUCIONA EL BUG DEL BRAZO TRABADO)
    function setArmsState(state) {
        armsGroup.setAttribute('class', 'arms-' + state);
    }

    function moveEyes(normX) {
        const dx = normX * 5;
        eyeL.setAttribute('transform', `translate(${dx}, 0)`);
        eyeR.setAttribute('transform', `translate(${dx}, 0)`);
    }

    function setMouth(nivel) {
        mouthBG.style.display   = nivel === 0 ? '' : 'none';
        mouthOut.style.display  = nivel === 0 ? '' : 'none';
        mouthSm.style.display   = nivel === 1 ? '' : 'none';
        mouthMed.style.display  = nivel === 2 ? '' : 'none';
        mouthLg.style.display   = nivel === 3 ? '' : 'none';
    }

    function updateInteractions(input) {
        const val = input.value;
        const ratio = Math.min(val.length / 20, 1);
        moveEyes(ratio * 2 - 1);
        if (val.length === 0) setMouth(0);
        else if (val.length < 5) setMouth(1);
        else if (val.length < 15) setMouth(2);
        else setMouth(3);
    }

    // Eventos Email
    emailInput.addEventListener('focus', function() { setArmsState('hidden'); updateInteractions(this); });
    emailInput.addEventListener('input', function() { updateInteractions(this); });
    emailInput.addEventListener('blur', function() { moveEyes(0); setMouth(0); });

    // Eventos Password
    passwordInput.addEventListener('focus', function() {
        if (this.type === 'password') {
            setArmsState('covering');
            setMouth(0);
            moveEyes(0);
        } else {
            setArmsState('peeking');
            updateInteractions(this);
        }
    });

    passwordInput.addEventListener('input', function() {
        if (this.type === 'text') updateInteractions(this);
    });

    passwordInput.addEventListener('blur', function() {
        setArmsState('hidden');
        setMouth(0);
        moveEyes(0);
    });

    // --- CORRECCIÓN DEFINITIVA DEL BOTÓN VISUALIZAR ---
    togglePass.addEventListener('click', function (e) {
        e.preventDefault();

        const isPassword = passwordInput.type === 'password';
        passwordInput.type = isPassword ? 'text' : 'password';
        eyeIcon.className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';

        if (isPassword) {
            // Pasamos a texto visible, el Yeti espía
            setArmsState('peeking');
            updateInteractions(passwordInput);
        } else {
            // Volvemos a ocultar, el Yeti tapa los ojos inmediatamente
            setArmsState('covering');
            setMouth(0);
            moveEyes(0);
        }

        // Devolver el foco para mantener interactividad sin bugear el evento blur
        passwordInput.focus();
    });

    // Envío y SweetAlert
    const loginForm = document.getElementById('form-login');
    if (loginForm) {
        loginForm.addEventListener('submit', function (e) {
            if (this.checkValidity() && typeof Swal !== 'undefined') {
                Swal.fire({
                    title: 'Autenticando...',
                    text: 'Verificando datos en el servidor.',
                    allowOutsideClick: false,
                    allowEscapeKey: false,
                    showConfirmButton: false,
                    didOpen: function () { Swal.showLoading(); }
                });
            }
        });
    }

    @if (ViewBag.LoginExitoso != null && (bool)ViewBag.LoginExitoso == true)
    {
        <text>
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'success',
                title: '¡Acceso concedido!',
                text: 'Iniciando tu sesión...',
                confirmButtonColor: '#0284c7',
                confirmButtonText: 'Continuar'
            }).then(function () {
                window.location.href = '@Url.Action("Index", "Gessi")';
            });
        }
        </text>
    }

    @if (ViewBag.ErrorLogin != null)
    {
        <text>
        if (typeof Swal !== 'undefined') {
            Swal.fire({
                icon: 'error',
                title: 'Acceso Denegado',
                text: '@ViewBag.ErrorLogin',
                confirmButtonColor: '#0284c7',
                confirmButtonText: 'Intentar de nuevo'
            });
        }
        </text>
    }
});
</script>