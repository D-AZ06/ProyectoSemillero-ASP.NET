@model ProyectoSemillero_ASP.NET.Models.ValidarInicioSesion
@{
    ViewData["Title"] = "Iniciar Sesión";
    // Asigna el nuevo layout secundario y limpio
    Layout = "~/Views/Shared/_LayoutSimple.cshtml";
}

<div class="container d-flex flex-column justify-content-center align-items-center" style="min-height: calc(100vh - 70px);">

    <div class="p-5 rounded shadow-sm bg-white" style="border-top: 5px solid #0284c7; max-width: 450px; width: 100%;">

        <div class="text-center mb-4">
            <i class="bi bi-person-circle display-4 text-info mb-2"></i>
            <h2 class="text-secondary fw-bold">Iniciar Sesión</h2>
            <p class="text-muted">Ingrese sus credenciales de acceso</p>
        </div>

        @using (Html.BeginForm("IniciarSesion", "Home", FormMethod.Post, new { id = "form-login" }))
        {
            @Html.AntiForgeryToken()

            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            <div class="mb-3">
                <label class="form-label fw-bold text-secondary">Correo Electrónico</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    @Html.TextBoxFor(m => m.Correo, new { @class = "form-control", placeholder = "ejemplo@correo.com" })
                </div>
                @Html.ValidationMessageFor(m => m.Correo, "", new { @class = "text-danger small" })
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-secondary">Contraseña</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    @Html.PasswordFor(m => m.Contrasena, new { @class = "form-control", placeholder = "********" })
                </div>
                @Html.ValidationMessageFor(m => m.Contrasena, "", new { @class = "text-danger small" })
            </div>

            <div class="d-flex gap-3">
                <a href="@Url.Action("Bienvenida", "Home")" class="btn btn-lg w-50 btn-light shadow-sm" style="border-radius: 8px; border: 1px solid #dee2e6; color: #6c757d;">
                    <i class="bi bi-arrow-left-circle me-2"></i> Cancelar
                </a>

                <button type="submit" class="btn btn-lg w-50 text-white shadow-sm" style="background-color: #0284c7; border-radius: 8px;">
                    <i class="bi bi-box-arrow-in-right me-2"></i> Ingresar
                </button>
            </div>
        }
    </div>
</div>

<script>
        document.addEventListener("DOMContentLoaded", function () {

            // 1. EVALÚA SI EL LOGIN FUE EXITOSO
            @if (ViewBag.LoginExitoso != null && (bool)ViewBag.LoginExitoso == true)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: '¡Acceso concedido!',
                    text: 'Iniciando tu sesión...',
                    confirmButtonColor: '#0284c7',
                    confirmButtonText: 'Continuar'
                }).then((result) => {
                    window.location.href = '@Url.Action("Index", "Gessi")';
                });
                </text>
            }

            // 2. EVALÚA SI HUBO ERROR EN LAS CREDENCIALES
            @if (ViewBag.ErrorLogin != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Acceso Denegado',
                    text: '@ViewBag.ErrorLogin',
                    confirmButtonColor: '#0284c7',
                    confirmButtonText: 'Intentar de nuevo'
                });
                </text>
            }
        });

        // 3. PANTALLA DE CARGA MIENTRAS BUSCA EN MONGODB ATLAS
        document.getElementById('form-login').addEventListener('submit', function (e) {
            if (this.checkValidity()) {
                Swal.fire({
                    title: 'Autenticando...',
                    text: 'Verificando datos en el servidor.',
                    allowOutsideClick: false,
                    allowEscapeKey: false,
                    showConfirmButton: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });
            }
        });

        // Este código borra el historial "hacia adelante" del navegador
        // una vez que el usuario aterriza en la pantalla de Login.
        function prevenirRetroceso() {
            window.history.pushState(null, "", window.location.href);
            window.onpopstate = function () {
                window.history.pushState(null, "", window.location.href);
            };
        }

        // Lo ejecutamos apenas cargue la página
</script>
