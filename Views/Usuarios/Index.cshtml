@model IEnumerable<ProyectoSemillero_ASP.NET.Models.DatosUsuario>

@{
    ViewBag.Title = "Gestionar Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <h3 class="fw-bold text-dark mb-0">
        <i class="bi bi-people-fill text-primary me-2"></i> Gestionar Usuarios
    </h3>
    <a href="@Url.Action("Agregar", "Usuarios")" class="btn btn-success fw-bold shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Agregar Usuario
    </a>
</div>

<div class="card bg-light border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <div class="row g-2 align-items-center">
            <div class="col-12 col-md-auto">
                <span class="fw-bold text-secondary mb-0"><i class="bi bi-funnel me-1"></i> Consultar por parámetros:</span>
            </div>
            <div class="col-12 col-md-3">
                <select class="form-select border-info">
                    <option value="">Seleccione filtro...</option>
                    <option value="1">ID Usuario</option>
                    <option value="2">Nombre</option>
                    <option value="3">Rol</option>
                </select>
            </div>
            <div class="col-12 col-md">
                <input type="text" class="form-control border-info" placeholder="Ingrese el valor a buscar...">
            </div>
            <div class="col-12 col-md-auto">
                <button class="btn btn-info text-white fw-bold px-4 w-100">
                    <i class="bi bi-search"></i> Consultar
                </button>
            </div>
        </div>
    </div>
</div>

<div class="table-responsive shadow-sm rounded-3 border">
    <table class="table table-hover table-striped mb-0 align-middle">
        <thead class="table-dark">
            <tr>
                <th scope="col" class="py-3 ps-3">ID</th>
                <th scope="col" class="py-3">Nombre</th>
                <th scope="col" class="py-3">Correo</th>
                <th scope="col" class="py-3">Rol</th>
                <th scope="col" class="py-3 text-center">ID Semillero</th>
                <th scope="col" class="py-3 text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                // Si la BD devuelve datos, creamos una fila por cada usuario
                foreach (var usuario in Model)
                {
                    <tr>
                        <td class="ps-3 fw-medium">@usuario.IdUsuario</td>
                        <td>@usuario.NombreUsuario</td>
                        <td>@usuario.CorreoUsuario</td>
                        <td>
                            @if (usuario.RolUsuario == "Líder")
                            {
                                <span class="badge bg-primary">@usuario.RolUsuario</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@usuario.RolUsuario</span>
                            }
                        </td>
                        <td class="text-center">@usuario.IdSemillero</td>
                        <td class="text-center">
                            <a href="@Url.Action("Modificar", "Usuarios", new { id = usuario.IdUsuario })" class="btn btn-sm btn-outline-primary me-1" title="Modificar">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" title="Eliminar" onclick="confirmarEliminacion(@usuario.IdUsuario)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">
                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                        No se encontraron usuarios registrados en la base de datos.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        // 1. Mostrar mensaje de éxito si viene del controlador (Agregar, Modificar o Eliminar)
        var mensajeExito = '@TempData["Exito"]';
        if (mensajeExito && mensajeExito !== '') {
            Swal.fire({
                icon: 'success',
                title: '¡Operación Exitosa!',
                text: mensajeExito,
                confirmButtonColor: '#0284c7'
            });
        }

        // 2. Mostrar mensaje de error si algo sale mal
        var mensajeError = '@TempData["Error"]';
        if (mensajeError && mensajeError !== '') {
            Swal.fire({
                icon: 'error',
                title: 'Oops...',
                text: mensajeError,
                confirmButtonColor: '#dc3545'
            });
        }

        // 3. Función para confirmar antes de eliminar
        function confirmarEliminacion(id) {
            Swal.fire({
                title: '¿Estás completamente seguro?',
                text: "Esta acción borrará al usuario de forma permanente y no se puede deshacer.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545', /* Rojo para advertir peligro */
                cancelButtonColor: '#6c757d', /* Gris para cancelar */
                confirmButtonText: '<i class="bi bi-trash"></i> Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Si el usuario confirma, lo redirigimos a la acción Eliminar de tu Controlador
                    window.location.href = '@Url.Action("Eliminar", "Usuarios")?id=' + id;
                }
            });
        }
    </script>
}