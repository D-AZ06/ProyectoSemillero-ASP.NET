@model ProyectoSemillero_ASP.NET.Models.DatosUsuario

@{
    ViewBag.Title = "Modificar Usuario";
    Layout = "~/Views/Shared/_LayoutSimple.cshtml";
}

<div class="row justify-content-center w-100 m-0">
    <div class="col-12 col-md-8 col-lg-6 p-0">
        <div class="card shadow-sm border-0 rounded-3 mt-4 w-100" style="border-top: 4px solid #0284c7 !important;">

            <div class="card-header bg-white border-bottom py-3 d-flex align-items-center">
                <a href="@Url.Action("Index", "Usuarios")" id="btn-volver" class="btn btn-sm btn-outline-secondary me-3" title="Volver">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h4 class="mb-0 fw-bold text-dark"><i class="bi bi-pencil-square text-primary me-2"></i> Modificar Usuario</h4>
            </div>

            <div class="card-body p-4">
                @using (Html.BeginForm("Modificar", "Usuarios", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted">Identificación (ID) - No modificable</label>
                        @Html.TextBoxFor(m => m.IdUsuario, new { @class = "form-control bg-light", @readonly = "readonly" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre Completo</label>
                        @Html.TextBoxFor(m => m.NombreUsuario, new { @class = "form-control", required = "required" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Correo Electrónico</label>
                        @Html.TextBoxFor(m => m.CorreoUsuario, new { @class = "form-control", type = "email", required = "required" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Contraseña</label>
                        @Html.TextBoxFor(m => m.ContrasenaUsuario, new { @class = "form-control", required = "required" })
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Rol en el Semillero</label>
                        @Html.DropDownListFor(m => m.RolUsuario, new SelectList(new[] { "Estudiante", "Investigador", "Co-Líder" }), "Seleccione un rol...", new { @class = "form-select", required = "required" })
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn text-white fw-bold py-2" style="background-color: #0284c7;">
                            <i class="bi bi-arrow-clockwise me-1"></i> Actualizar Datos
                        </button>
                    </div>
                }
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // Capturamos el botón por su ID
            const btnVolver = document.getElementById('btn-volver');

            if (btnVolver) {
                btnVolver.addEventListener('click', function (e) {
                    // Evitamos que el enlace nos lleve a otra página inmediatamente
                    e.preventDefault();

                    // Guardamos la ruta a la que iba a ir (Index de Usuarios)
                    const urlDestino = this.getAttribute('href');

                    // Lanzamos la alerta de confirmación
                    Swal.fire({
                        title: '¿Estás seguro de salir?',
                        text: "Si regresas, perderás los cambios que no hayas actualizado.",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#d33', // Rojo para la acción de salir/peligro
                        cancelButtonColor: '#6c757d', // Gris para cancelar
                        confirmButtonText: '<i class="bi bi-box-arrow-left"></i> Sí, salir',
                        cancelButtonText: 'Cancelar'
                    }).then((result) => {
                        // Si el usuario da clic en "Sí, salir"
                        if (result.isConfirmed) {
                            window.location.href = urlDestino;
                        }
                    });
                });
            }

        });
    </script>
}