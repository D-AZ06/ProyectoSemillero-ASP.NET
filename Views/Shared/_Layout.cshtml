<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - GesSi</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --bg-body: #f4f7f6;
            --bg-sidebar: #2c3e50;
            --bg-sidebar-hover: #34495e;
            --blue-light: #e0f2fe;
            --blue-primary: #0284c7;
            --navbar-height: 70px; /* Altura fija para la barra superior */
            --sidebar-width: 260px; /* Ancho fijo del menú */
        }

        body {
            background-color: var(--bg-body);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow-x: hidden;
            margin: 0;
        }

        /* --- 1 y 2: BARRA SUPERIOR FIJA Y LOGO VISIBLE --- */
        .top-navbar {
            height: var(--navbar-height);
            background-color: white;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            position: fixed; /* Se queda pegada arriba al hacer scroll */
            top: 0;
            left: 0;
            right: 0;
            z-index: 1050; /* Por encima de todo en la página */
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 1.5rem;
        }

        /* Espacio para que el contenido no quede oculto detrás de la barra fija */
        #wrapper {
            padding-top: var(--navbar-height);
        }

        /* --- 3: MENÚ LATERAL (SIDEBAR) --- */
        #sidebar-wrapper {
            position: fixed;
            top: var(--navbar-height);
            left: 0;
            width: var(--sidebar-width);
            height: calc(100vh - var(--navbar-height));
            background-color: var(--bg-sidebar);
            color: white;
            overflow-y: auto;
            z-index: 1040;
            transition: transform 0.3s ease-in-out;
            /* Por defecto en móvil: oculto hacia la izquierda */
            transform: translateX(-100%);
            box-shadow: 2px 0 5px rgba(0,0,0,0.1);
        }

        /* En móvil: cuando se abre, flota POR ENCIMA del contenido (no lo achica) */
        #wrapper.toggled #sidebar-wrapper {
            transform: translateX(0);
            box-shadow: 5px 0 15px rgba(0,0,0,0.3);
        }

        /* Área de contenido principal */
        #page-content-wrapper {
            width: 100%;
            transition: margin-left 0.3s ease-in-out, width 0.3s ease-in-out;
        }

        /* Comportamiento en pantallas grandes (Desktop) */
        @@media (min-width: 768px) {
            #sidebar-wrapper {
                transform: translateX(0); /* Visible por defecto */
                box-shadow: none;
                border-right: 1px solid rgba(0,0,0,0.1);
            }

            #page-content-wrapper {
                margin-left: var(--sidebar-width); /* Empuja el contenido */
                width: calc(100% - var(--sidebar-width));
            }
            /* En PC: Si se oculta el menú, el contenido ocupa toda la pantalla */
            #wrapper.toggled #sidebar-wrapper {
                transform: translateX(-100%);
            }

            #wrapper.toggled #page-content-wrapper {
                margin-left: 0;
                width: 100%;
            }
        }

        /* --- ESTILOS INTERNOS DEL MENÚ --- */
        .sidebar-user-info {
            padding: 1.5rem 1rem;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            background-color: rgba(0,0,0,0.15);
        }

        .list-group-item-action {
            background-color: transparent;
            color: #cbd5e1;
            border: none;
            padding: 0.8rem 1.5rem;
            font-size: 0.95rem;
            transition: all 0.3s;
        }

            .list-group-item-action:hover, .list-group-item-action:focus {
                background-color: var(--bg-sidebar-hover);
                color: white;
                border-left: 4px solid var(--blue-primary);
            }

        .list-group-item i {
            margin-right: 10px;
            font-size: 1.1rem;
        }

        /* Componentes de la vista */
        .main-content-card {
            background-color: white;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            padding: 20px;
            min-height: 500px;
        }

        /* Ajuste de botones superiores para celular */
        @@media (max-width: 576px) {
            .btn-text {
                display: none;
            }
            /* Oculta el texto, deja solo íconos */
            .top-navbar {
                padding: 0 1rem;
            }
        }
    </style>
</head>
<body>

    <header class="top-navbar">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-light" id="menu-toggle" title="Alternar menú" style="border: 1px solid #ddd;">
                <i class="bi bi-list fs-4"></i>
            </button>

            <div class="fs-4 fw-bold text-info m-0 d-flex align-items-center gap-2">
                <i class="bi bi-cpu"></i>
                <span class="d-none d-sm-inline text-dark">GesSi</span>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-info">
                <i class="bi bi-robot"></i> <span class="btn-text">Ayuda IA</span>
            </button>

            <button type="button" class="btn btn-outline-danger" onclick="confirmarSalida('@Url.Action("IniciarSesion", "Home")')">
                <i class="bi bi-box-arrow-right"></i> <span class="btn-text">Salir</span>
            </button>
        </div>
    </header>

    <div id="wrapper">
        <div id="sidebar-wrapper">
            <div class="sidebar-user-info">
                <div class="fw-bold">Bienvenido Líder</div>
                <small class="text-light">¿Qué desea gestionar hoy?</small>
            </div>
            <div class="list-group list-group-flush mt-2">
                <a href="@Url.Action("Index", "Usuarios")" class="list-group-item list-group-item-action"><i class="bi bi-person-badge"></i> Usuarios</a>
                <a href="@Url.Action("Index", "Semillero")" class="list-group-item list-group-item-action"><i class="bi bi-tree"></i> Semillero</a>
                <a href="@Url.Action("Index", "Proyectos")" class="list-group-item list-group-item-action"><i class="bi bi-folder2-open"></i> Proyectos</a>
                <a href="@Url.Action("Index", "Actividades")" class="list-group-item list-group-item-action"><i class="bi bi-card-checklist"></i> Actividades</a>
                <a href="@Url.Action("Index", "Fases")" class="list-group-item list-group-item-action"><i class="bi bi-signpost-split"></i> Fases</a>
                <a href="@Url.Action("Index", "Reuniones")" class="list-group-item list-group-item-action"><i class="bi bi-people"></i> Reuniones</a>
                <a href="@Url.Action("Index", "Eventos")" class="list-group-item list-group-item-action"><i class="bi bi-calendar-event"></i> Eventos</a>
                <a href="@Url.Action("Index", "Patrocinadores")" class="list-group-item list-group-item-action"><i class="bi bi-heart"></i> Patrocinadores</a>
                <a href="@Url.Action("Index", "Reportes")" class="list-group-item list-group-item-action"><i class="bi bi-file-earmark-bar-graph"></i> Reportes</a>
            </div>
        </div>

        <div id="page-content-wrapper">
            <main class="container-fluid p-3 p-md-4">

                <div class="main-content-card position-relative">
                    @RenderBody()
                </div>

            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.getElementById("menu-toggle").addEventListener("click", function (e) {
            e.preventDefault();
            document.getElementById("wrapper").classList.toggle("toggled");
        });
    </script>

    @RenderSection("Scripts", required: false)

    <script>
        function confirmarSalida(urlDestino) {
            // Primera alerta: Pregunta si está seguro
            Swal.fire({
                title: '¿Deseas cerrar sesión?',
                text: "Tendrás que volver a ingresar tus credenciales para acceder al sistema.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#0284c7',
                cancelButtonColor: '#dc3545',
                confirmButtonText: 'Sí, salir',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {

                    // Segunda alerta: Muestra el éxito AQUÍ MISMO en el layout
                    Swal.fire({
                        icon: 'success',
                        title: '¡Hasta pronto!',
                        text: 'Tu sesión se ha cerrado correctamente.',
                        confirmButtonColor: '#0284c7',
                        confirmButtonText: 'OK',
                        allowOutsideClick: false, // Evita que se cierre haciendo clic por fuera
                        allowEscapeKey: false
                    }).then(() => {
                        // Cuando el usuario le da "OK", lo enviamos a destruir la sesión
                        window.location.href = urlDestino;
                    });

                }
            });
        }
    </script>
</body>
</html>