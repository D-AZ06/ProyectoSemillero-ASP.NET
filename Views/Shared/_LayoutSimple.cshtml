<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GesSi</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"> <!-- Bootstrap CSS  -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"> <!-- Bootstrap Icons -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script> <!-- SweetAlert2 para alertas y mensajes -->

    <style>
        body {
            background-color: #f4f7f6;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding-top: 70px;
        }

        .top-navbar-login {
            height: 70px;
            background-color: white;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1050;
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
        }
    </style>
</head>
<body>

    <header class="top-navbar-login">
        <div class="fs-4 fw-bold text-info m-0 d-flex align-items-center gap-2">
            <i class="bi bi-cpu"></i>
            <span class="text-dark">GesSi</span>
        </div>
    </header>

    <div class="container d-flex flex-column justify-content-center align-items-center" style="min-height: calc(100vh - 70px);">
        @RenderBody()
    </div>

    @RenderSection("Scripts", required: false)

</body>
</html>