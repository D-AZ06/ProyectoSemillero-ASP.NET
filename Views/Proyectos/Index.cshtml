@model IEnumerable<ProyectoSemillero_ASP.NET.Models.DatosProyecto>

@{
    ViewBag.Title = "Gestionar Proyectos";

    // Creamos la variable vacía al inicio
    string rolActual = "";

    // Validamos de forma tradicional si la sesión no es nula
    if (Session["Rol"] != null)
    {
        rolActual = Session["Rol"].ToString();
    }
    else
    {
        rolActual = ""; // Si es nula, se asegura de dejarla vacía
    }
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <h3 class="fw-bold text-dark mb-0">
        <i class="bi bi-journal-bookmark-fill text-primary me-2"></i> Gestionar Proyectos
    </h3>

    @if (rolActual != "Investigador")
    {
        <a href="@Url.Action("Agregar", "Proyectos")" class="btn btn-success fw-bold shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Agregar Proyecto
        </a>
    }
</div>

<div class="card bg-light border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form action="@Url.Action("Index", "Proyectos")" method="get" id="formBusqueda">
            <div class="row g-2 align-items-center">
                <div class="col-12 col-md-auto">
                    <span class="fw-bold text-secondary mb-0"><i class="bi bi-funnel me-1"></i> Consultar por parámetros:</span>
                </div>

                <div class="col-12 col-md-3">
                    <select class="form-select border-info" id="selectFiltro" name="tipoFiltro">
                        <option value="">Seleccione filtro...</option>
                        <option value="idProyecto">ID Proyecto</option>
                        <option value="tituloProyecto">Título</option>
                        <option value="objetivoProyecto">Objetivo</option>
                        <option value="descripcionProyecto">Descripción</option>
                        <option value="fechaInicioProyecto">Fecha Exacta de Inicio</option>
                        <option value="mesInicioProyecto">Mes de Inicio</option>
                        <option value="fechaFinProyecto">Fecha Exacta de Fin</option>
                        <option value="mesFinProyecto">Mes de Fin</option>
                        <option value="idSemillero">ID Semillero</option>
                        <option value="nombreSemillero">Nombre de Semillero</option>
                    </select>
                </div>

                <div class="col-12 col-md" id="contenedorInput">
                    <input type="text" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="Seleccione un filtro primero..." disabled>
                </div>

                <datalist id="opcionesSugeridas"></datalist>

                <div class="col-12 col-md-auto">
                    <button type="submit" class="btn btn-info text-white fw-bold px-4 w-100" id="btnConsultar" disabled>
                        <i class="bi bi-search"></i> Consultar
                    </button>
                </div>

                @if (Request.QueryString["tipoFiltro"] != null)
                {
                    <div class="col-12 col-md-auto">
                        <a href="@Url.Action("Index", "Proyectos")" class="btn btn-secondary fw-bold w-100">
                            <i class="bi bi-arrow-clockwise"></i> Limpiar
                        </a>
                    </div>
                }
            </div>
        </form>
    </div>
</div>

<div class="table-responsive shadow-sm rounded-3 border">
    <table class="table table-hover table-striped mb-0 align-middle" id="tablaProyectos">
        <thead class="table-dark">
            <tr>
                <th scope="col" class="py-3 ps-3">ID</th>
                <th scope="col" class="py-3">Título</th>
                <th scope="col" class="py-3">Objetivo</th>
                <th scope="col" class="py-3">Descripción</th>
                <th scope="col" class="py-3">Inicio</th>
                <th scope="col" class="py-3">Fin</th>
                <th scope="col" class="py-3 text-center">Semillero</th>
                <th scope="col" class="py-3 text-center" style="min-width: 160px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var proyecto in Model)
                {
                    <tr>
                        <td class="ps-3 fw-medium data-idProyecto">@proyecto.IdProyecto</td>
                        <td class="fw-bold text-primary data-tituloProyecto" style="max-width: 180px;">@proyecto.TituloProyecto</td>
                        <td class="data-objetivoProyecto" style="max-width: 200px; white-space: normal; word-wrap: break-word;">
                            <small class="text-muted">@proyecto.ObjetivoProyecto</small>
                        </td>
                        <td class="data-descripcionProyecto" style="max-width: 250px; white-space: normal; word-wrap: break-word;">
                            <small class="text-dark">@proyecto.DescripcionProyecto</small>
                        </td>
                        <td class="data-fechaInicioProyecto">@proyecto.FechaInicioProyecto</td>
                        <td class="data-fechaFinProyecto">@proyecto.FechaFinProyecto</td>

                        <td class="text-center data-idSemillero">
                            <span class="badge bg-secondary mb-1">ID: @proyecto.IdSemillero</span><br />
                            @{
                                var dicSemilleros = ViewBag.DiccionarioSemilleros as Dictionary<int, string>;
                                string nombreSemillero = "Desconocido";
                                if (dicSemilleros != null && dicSemilleros.ContainsKey(proyecto.IdSemillero))
                                {
                                    nombreSemillero = dicSemilleros[proyecto.IdSemillero];
                                }
                            }
                            <small class="fw-bold text-dark">@nombreSemillero</small>
                        </td>

                        <td class="text-center">
                            <button type="button" class="btn btn-sm btn-outline-secondary me-1" title="Ver Actividades" onclick="alert('Próximamente...');">
                                <i class="bi bi-list-task"></i>
                            </button>

                            @if (rolActual != "Investigador")
                            {
                                <a href="@Url.Action("Modificar", "Proyectos", new { id = proyecto.IdProyecto })" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmarEliminacion(@proyecto.IdProyecto)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center py-4 text-muted">
                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                        No se encontraron proyectos registrados o que coincidan con la búsqueda.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        const datosAutocompletado = {
            idProyecto: [...new Set(Array.from(document.querySelectorAll('.data-idProyecto')).map(el => el.textContent.trim()))],
            tituloProyecto: [...new Set(Array.from(document.querySelectorAll('.data-tituloProyecto')).map(el => el.textContent.trim()))],
            objetivoProyecto: [...new Set(Array.from(document.querySelectorAll('.data-objetivoProyecto')).map(el => el.textContent.trim()))],
            descripcionProyecto: [...new Set(Array.from(document.querySelectorAll('.data-descripcionProyecto')).map(el => el.textContent.trim()))],
            idSemillero: [...new Set(Array.from(document.querySelectorAll('.data-idSemillero span')).map(el => el.textContent.replace('ID: ', '').trim()))],
            nombreSemillero: [...new Set(Array.from(document.querySelectorAll('.data-idSemillero small')).map(el => el.textContent.trim()))]
        };

        const selectFiltro = document.getElementById('selectFiltro');
        const contenedorInput = document.getElementById('contenedorInput');
        const btnConsultar = document.getElementById('btnConsultar');
        const datalist = document.getElementById('opcionesSugeridas');

        selectFiltro.addEventListener('change', function () {
            const filtroSeleccionado = this.value;
            datalist.innerHTML = '';

            if (!filtroSeleccionado) {
                contenedorInput.innerHTML = '<input type="text" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="Seleccione un filtro primero..." disabled>';
                btnConsultar.disabled = true;
                return;
            }

            btnConsultar.disabled = false;
            let nuevoInput = '';

            if (filtroSeleccionado === 'fechaInicioProyecto' || filtroSeleccionado === 'fechaFinProyecto') {
                nuevoInput = `<input type="date" class="form-control border-info" id="inputValor" name="valorFiltro" required>`;
            }
            else if (filtroSeleccionado === 'mesInicioProyecto' || filtroSeleccionado === 'mesFinProyecto') {
                nuevoInput = `<input type="month" class="form-control border-info" id="inputValor" name="valorFiltro" required>`;
            }
            else {
                let esNumero = (filtroSeleccionado === 'idProyecto' || filtroSeleccionado === 'idSemillero');
                let tipoInput = esNumero ? 'number' : 'text';
                let placeholder = esNumero ? 'Seleccione o ingrese un ID...' : 'Escriba para buscar sugerencias...';
                let extraAttr = esNumero ? 'min="1"' : '';

                nuevoInput = `<input type="${tipoInput}" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="${placeholder}" ${extraAttr} list="opcionesSugeridas" autocomplete="off" required>`;

                if (datosAutocompletado[filtroSeleccionado]) {
                    datosAutocompletado[filtroSeleccionado].forEach(valor => {
                        let option = document.createElement('option');
                        option.value = valor;
                        datalist.appendChild(option);
                    });
                }
            }

            contenedorInput.innerHTML = nuevoInput;
            configurarValidacionEnTiempoReal();
        });

        function configurarValidacionEnTiempoReal() {
            const inputValor = document.getElementById('inputValor');
            const formBusqueda = document.getElementById('formBusqueda');

            formBusqueda.addEventListener('submit', function (e) {
                const filtro = selectFiltro.value;
                const valor = inputValor.value.trim();

                if (!valor) {
                    e.preventDefault();
                    Swal.fire({ icon: 'warning', title: 'Campo requerido', text: 'Por favor ingrese un valor para buscar.', confirmButtonColor: '#0284c7' });
                    return;
                }

                if (['tituloProyecto', 'objetivoProyecto', 'descripcionProyecto', 'idProyecto', 'idSemillero', 'nombreSemillero'].includes(filtro)) {
                    if (!datosAutocompletado[filtro].includes(valor)) {
                        e.preventDefault();
                        Swal.fire({ icon: 'error', title: 'Dato no válido', text: 'El valor ingresado no coincide con ningún registro existente.', confirmButtonColor: '#dc3545' });
                    }
                }
            });
        }

        var mensajeExito = '@TempData["Exito"]';
        if (mensajeExito && mensajeExito !== '') {
            Swal.fire({ icon: 'success', title: '¡Operación Exitosa!', text: mensajeExito, confirmButtonColor: '#0284c7' });
        }
        var mensajeError = '@TempData["Error"]';
        if (mensajeError && mensajeError !== '') {
            Swal.fire({ icon: 'error', title: 'Oops...', text: mensajeError, confirmButtonColor: '#dc3545' });
        }

        function confirmarEliminacion(id) {
            Swal.fire({
                title: '¿Estás seguro?',
                text: "Esta acción borrará el proyecto permanentemente.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("Eliminar", "Proyectos")?id=' + id;
                }
            });
        }
    </script>
}