@{
    ViewBag.Title = "Agregar Actividad";
    Layout = "~/Views/Shared/_LayoutSimple.cshtml";

    bool proyectoFijo = ViewBag.ProyectoFijo ?? false;
    var proyectosCombobox = ViewBag.ProyectosMapeados as List<ProyectoSemillero_ASP.NET.Models.DatosProyecto>;
}

<style>
    body > .container {
        display: block !important;
        padding-top: 2rem !important;
    }
</style>

<div class="w-100 text-start mb-5" style="max-width: 700px; margin: 0 auto;">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h3 class="fw-bold text-dark mb-0">
            <i class="bi bi-plus-circle-fill text-success me-2"></i> Registrar Nueva Actividad
        </h3>

        @if (proyectoFijo)
        {
            <a href="@Url.Action("PorProyecto", "Actividades", new { idProyecto = ViewBag.IdProyecto })" class="btn btn-outline-secondary fw-bold shadow-sm">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
        }
        else
        {
            <a href="@Url.Action("Index", "Actividades")" class="btn btn-outline-secondary fw-bold shadow-sm">
                <i class="bi bi-arrow-left"></i> Cancelar
            </a>
        }
    </div>

    <div class="card shadow-sm border-0 bg-white">
        <div class="card-body p-4">
            <form action="@Url.Action("Agregar", "Actividades")" method="post" id="formAgregarActividad">

                <input type="hidden" name="vinoDesdeProyecto" value="@(proyectoFijo ? "true" : "false")" />

                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary"><i class="bi bi-folder-fill me-1"></i> Proyecto Asociado</label>

                    @if (proyectoFijo)
                    {
                        <input type="hidden" name="idProyecto" value="@ViewBag.IdProyecto" />
                        <div class="input-group">
                            <span class="input-group-text bg-light text-dark fw-bold">ID: @ViewBag.IdProyecto</span>
                            <input type="text" class="form-control bg-light text-muted fw-semibold border-secondary-subtle" value="@ViewBag.TituloProyecto" readonly disabled />
                        </div>
                    }
                    else
                    {
                        <select class="form-select border-info fw-medium" name="idProyecto" id="selectProyectoForm" required>
                            <option value="">-- Seleccione el proyecto de destino --</option>
                            @if (proyectosCombobox != null)
                            {
                                foreach (var proj in proyectosCombobox)
                                {
                                    <option value="@proj.IdProyecto">ID: @proj.IdProyecto - @proj.TituloProyecto</option>
                                }
                            }
                        </select>
                    }
                </div>

                <hr class="text-muted my-3" />

                <div class="mb-3">
                    <label for="nombreActividad" class="form-label fw-bold text-secondary"><i class="bi bi-bookmark-plus-fill me-1"></i> Nombre de la Actividad</label>
                    <input type="text" class="form-control border-secondary-subtle" id="nombreActividad" name="nombreActividad" placeholder="Ej. Diseño de la Base de Datos" maxlength="150" required autocomplete="off" />
                </div>

                <div class="row">
                    <div class="col-12 col-md-6 mb-3">
                        <label for="duracionValor" class="form-label fw-bold text-secondary"><i class="bi bi-stopwatch-fill me-1"></i> Duración Estimada</label>
                        <div class="input-group">
                            <input type="number" class="form-control border-secondary-subtle" id="duracionValor" name="duracionValor" min="1" placeholder="Cant." required />
                            <select class="form-select border-secondary-subtle fw-semibold" id="duracionUnidad" name="duracionUnidad" required>
                                <option value="Días">Días</option>
                                <option value="Semanas">Semanas</option>
                                <option value="Meses">Meses</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 mb-3">
                        <label for="fechaEntregaActividad" class="form-label fw-bold text-secondary"><i class="bi bi-calendar-check-fill me-1"></i> Fecha Máxima de Entrega</label>
                        <input type="date" class="form-control border-secondary-subtle" id="fechaEntregaActividad" name="fechaEntregaActividad" required />
                        <small class="text-muted" id="ayudaFecha"><i class="bi bi-info-circle"></i> Selecciona la duración para calcular la fecha recomendada.</small>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success fw-bold px-4 shadow-sm" id="btnGuardarActividad">
                        <i class="bi bi-check-circle me-1"></i> Guardar Actividad
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const txtValor = document.getElementById('duracionValor');
        const cboUnidad = document.getElementById('duracionUnidad');
        const txtFecha = document.getElementById('fechaEntregaActividad');
        const ayudaFecha = document.getElementById('ayudaFecha');

        // 1. Al cargar la página, la restricción base absoluta es que no se pueda elegir ni hoy ni ayer
        function establecerMinimoAbsoluto() {
            let mañana = new Date();
            mañana.setDate(mañana.getDate() + 1); // Sumamos 1 día a hoy

            const yyyy = mañana.getFullYear();
            const mm = String(mañana.getMonth() + 1).padStart(2, '0');
            const dd = String(mañana.getDate()).padStart(2, '0');

            const fechaMinimaBase = `${yyyy}-${mm}-${dd}`;
            txtFecha.min = fechaMinimaBase;
        }

        // 2. Función matemática para calcular y bloquear la fecha según el tiempo ingresado
        function calcularFechaProyectada() {
            const valor = parseInt(txtValor.value) || 0;
            const unidad = cboUnidad.value;

            if (valor <= 0) {
                establecerMinimoAbsoluto();
                ayudaFecha.innerHTML = `<i class="bi bi-info-circle text-muted"></i> Ingrese una duración válida numérica mayor a 0.`;
                return;
            }

            let fechaCalculada = new Date(); // Partimos de hoy

            if (unidad === 'Días') {
                fechaCalculada.setDate(fechaCalculada.getDate() + valor);
            } else if (unidad === 'Semanas') {
                fechaCalculada.setDate(fechaCalculada.getDate() + (valor * 7));
            } else if (unidad === 'Meses') {
                fechaCalculada.setMonth(fechaCalculada.getMonth() + valor);
            }

            // Convertir objeto de fecha a formato estándar HTML5 (YYYY-MM-DD)
            const yyyy = fechaCalculada.getFullYear();
            const mm = String(fechaCalculada.getMonth() + 1).padStart(2, '0');
            const dd = String(fechaCalculada.getDate()).padStart(2, '0');
            const formatoFinal = `${yyyy}-${mm}-${dd}`;

            // Actualizamos la vista dinámicamente
            txtFecha.value = formatoFinal;
            txtFecha.min = formatoFinal; // "automáticamente no se puede colocar una fecha anterior a esta"
            ayudaFecha.innerHTML = `<i class="bi bi-lock-fill text-success"></i> Bloqueado: Fecha mínima calculada según duración del desarrollo.`;
        }

        // Escuchadores de eventos en tiempo real
        txtValor.addEventListener('input', calcularFechaProyectada);
        cboUnidad.addEventListener('change', calcularFechaProyectada);

        // Inicializar restricciones nativas del HTML
        document.addEventListener('DOMContentLoaded', establecerMinimoAbsoluto);

        // Loader de envío
        document.getElementById('formAgregarActividad').addEventListener('submit', function () {
            const btn = document.getElementById('btnGuardarActividad');
            btn.disabled = true;
            btn.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Guardando en MongoDB Atlas...`;
        });
    </script>
}