@model IEnumerable<ProyectoSemillero_ASP.NET.Models.DatosUsuario>

@{
    ViewBag.Title = "Integrantes del Semillero";
    Layout = "~/Views/Shared/_LayoutSimple.cshtml"; // Usamos tu layout sin menú lateral
    var semillero = ViewBag.Semillero as ProyectoSemillero_ASP.NET.Models.DatosSemillero;
}

<div class="row justify-content-center w-100 m-0">
    <div class="col-12 col-lg-10 p-0 mt-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="fw-bold text-dark mb-0">
                <i class="bi bi-people-fill text-primary me-2"></i> Integrantes del Semillero
            </h3>
            <a href="@Url.Action("Index", "Semillero")" class="btn btn-outline-secondary fw-bold shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Volver a Semilleros
            </a>
        </div>

        <div class="card shadow-sm mb-4" style="border: 2px solid #0dcaf0; border-radius: 8px;">
            <div class="card-body py-2 px-3 d-flex align-items-center">
                <span class="badge bg-info text-white fs-6 me-3 px-3 py-2">ID Semillero: @semillero.IdSemillero</span>
                <span class="fs-5 fw-bold text-dark">Nombre: <span class="text-secondary">@semillero.nombreSemillero</span></span>
            </div>
        </div>

        <div class="table-responsive shadow-sm rounded-3 border">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col" class="py-3 ps-3">ID Usuario</th>
                        <th scope="col" class="py-3">Nombre del Integrante</th>
                        <th scope="col" class="py-3">Correo Electrónico</th>
                        <th scope="col" class="py-3">Rol</th>
                        <th scope="col" class="py-3">Teléfono</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var integrante in Model)
                        {
                            <tr>
                                <td class="ps-3 text-muted fw-bold">@integrante.IdUsuario</td>
                                <td class="fw-bold text-dark">@integrante.NombreUsuario</td>
                                <td>@integrante.CorreoUsuario</td>
                                <td>
                                    @if (integrante.RolUsuario == "Líder")
                                    {
                                        <span class="badge bg-primary">@integrante.RolUsuario</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@integrante.RolUsuario</span>
                                    }
                                </td>
                                <td>@integrante.TelefonoUsuario</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                <i class="bi bi-person-x fs-2 d-block mb-2"></i>
                                Este semillero aún no tiene integrantes registrados en la base de datos.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>