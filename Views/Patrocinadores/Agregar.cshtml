@model ProyectoSemillero_ASP.NET.Models.DatosPatrocinador

@{
    ViewBag.Title = "Agregar Patrocinador";
    Layout = "~/Views/Shared/_LayoutSimple.cshtml";
}

<style>
    body > .container {
        display: block !important;
        padding-top: 2rem !important;
    }
</style>

<div class="w-100 text-start mb-5" style="max-width: 700px; margin: 0 auto;">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h3 class="fw-bold text-dark mb-0">
            <i class="bi bi-plus-circle-fill text-primary me-2"></i> Registrar Nuevo Patrocinador
        </h3>

        <a href="@Url.Action("Index", "Patrocinadores")" class="btn btn-outline-secondary fw-bold shadow-sm">
            <i class="bi bi-arrow-left"></i> Cancelar y Volver
        </a>
    </div>

    <div class="card shadow-sm border-0 bg-white">
        <div class="card-body p-4">

            @using (Html.BeginForm("Agregar", "Patrocinadores", FormMethod.Post, new { id = "formAgregarPatrocinador" }))
            {
                @Html.AntiForgeryToken()

                <div class="mb-3 bg-light p-3 rounded-3 border border-primary-subtle">
                    <label class="form-label fw-bold text-primary mb-1">
                        <i class="bi bi-hash me-1"></i> ID Patrocinador
                    </label>
                    @Html.TextBoxFor(m => m.IdPatrocinador, new { @class = "form-control bg-white text-muted fw-semibold", @type = "number", @required = "required", @readonly = "readonly" })
                    <small class="text-muted"><i class="bi bi-info-circle-fill text-info mt-2"></i> Este ID se genera o calcula automáticamente.</small>
                </div>

                <hr class="text-muted my-3" />

                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">
                        <i class="bi bi-building me-1"></i> Nombre de la Empresa / Organización
                    </label>
                    @Html.TextBoxFor(m => m.NombrePatrocinador, new { @class = "form-control border-secondary-subtle", @required = "required", @placeholder = "Nombre del aliado..." })
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">
                        <i class="bi bi-envelope-fill me-1"></i> Correo Electrónico
                    </label>
                    @Html.TextBoxFor(m => m.CorreoPatrocinador, new { @class = "form-control border-secondary-subtle", @type = "email", @required = "required", @placeholder = "ejemplo@dominio.com" })
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary" for="inputTelefono">
                        <i class="bi bi-telephone-fill me-1"></i> Contacto Telefónico
                    </label>
                    <input type="tel" class="form-control border-secondary-subtle" name="TelefonoPatrocinador" id="inputTelefono" required placeholder="Ej: 3001234567" value="@(Model != null && Model.TelefonoPatrocinador.ToString() != "0" ? Model.TelefonoPatrocinador.ToString() : "")" />
                    <small class="text-danger fw-semibold d-none" id="errorTelefono">
                        <i class="bi bi-exclamation-triangle-fill"></i> El teléfono debe tener entre 7 y 10 dígitos numéricos.
                    </small>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary" for="inputTipoPatrocinador">
                        <i class="bi bi-briefcase-fill me-1"></i> Tipo de patrocinio
                    </label>
                    @Html.TextBoxFor(m => m.TipoPatrocinador, new { @class = "form-control border-secondary-subtle", @required = "required", @placeholder = "Ej: Económico, Tecnológico, Logístico", @list = "listaTiposSugeridos", @autocomplete = "off", id = "inputTipoPatrocinador" })

                    <datalist id="listaTiposSugeridos">
                        @if (ViewBag.TiposSugeridos != null)
                        {
                            foreach (var tipo in ViewBag.TiposSugeridos)
                            {
                                <option value="@tipo"></option>
                            }
                        }
                    </datalist>
                    <small class="text-muted">
                    <i class="bi bi-lightbulb-fill text-warning mt-2"></i> Selecciona un tipo existente o escribe uno nuevo.</small>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success fw-bold px-4 shadow-sm" id="btnGuardarPatrocinador">
                        <i class="bi bi-save me-1"></i> Guardar Patrocinador
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var mensajeError = '@TempData["Error"]';
        if (mensajeError) {
            Swal.fire({ icon: 'error', title: 'Error', text: mensajeError, confirmButtonColor: '#dc3545' });
        }

        const form = document.getElementById('formAgregarPatrocinador');
        const btnSubmit = document.getElementById('btnGuardarPatrocinador');
        const inputTelefono = document.getElementById('inputTelefono');
        const errorTelefono = document.getElementById('errorTelefono');
        const inputTipoSoporte = document.getElementById('inputTipoPatrocinador');

        // Validación Realista del Teléfono en Tiempo Real
        inputTelefono.addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '');

            if (this.value.length > 10) {
                this.value = this.value.slice(0, 10);
            }

            if (this.value.length > 0 && this.value.length < 7) {
                errorTelefono.classList.remove('d-none');
                inputTelefono.classList.add('border-danger');
            } else {
                errorTelefono.classList.add('d-none');
                inputTelefono.classList.remove('border-danger');
            }
        });

        // Lógica de Estandarización de Tipos de Patrocinio
        const diccionarioTipos = [
            @if(ViewBag.TiposSugeridos != null) {
                foreach(var t in ViewBag.TiposSugeridos) {
                    @Html.Raw($"\"{HttpUtility.JavaScriptStringEncode(t)}\",")
                }
            }
        ];

        function normalizarTexto(texto) {
            if (!texto) return "";
            return texto.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase().trim();
        }

        inputTipoSoporte.addEventListener('blur', function() {
            const valorIngresado = normalizarTexto(this.value);
            if (!valorIngresado) return;

            const coincidencia = diccionarioTipos.find(t => normalizarTexto(t) === valorIngresado);

            if (coincidencia && coincidencia !== this.value.trim()) {
                this.value = coincidencia;

                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 3500,
                    timerProgressBar: true
                });

                Toast.fire({
                    icon: 'info',
                    title: 'Formato Unificado',
                    text: `Se ha auto-corregido a "${coincidencia}" para mantener el orden en el sistema.`
                });
            }
        });

        // Validación final antes de enviar + Loader
        form.addEventListener('submit', function (e) {
            if (inputTelefono.value.length < 7) {
                e.preventDefault();

                Swal.fire({
                    icon: 'warning',
                    title: 'Teléfono Inválido',
                    text: 'Asegúrate de ingresar un número telefónico real de entre 7 y 10 dígitos.',
                    confirmButtonColor: '#ffc107'
                });

                inputTelefono.focus();
                return;
            }

            setTimeout(() => {
                btnSubmit.disabled = true;
                btnSubmit.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Guardando Patrocinador...`;
            }, 10);
        });
    </script>
}