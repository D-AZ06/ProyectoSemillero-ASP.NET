@model IEnumerable<ProyectoSemillero_ASP.NET.Models.DatosEvento>

@{
    ViewBag.Title = "Gestionar Eventos";

    string rolActual = "";
    if (Session["Rol"] != null)
    {
        rolActual = Session["Rol"].ToString();
    }
    else
    {
        rolActual = "";
    }
}

<div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
    <h3 class="fw-bold text-dark mb-0">
        <i class="bi bi-calendar-event-fill text-primary me-2"></i> Gestionar Eventos
    </h3>

    @if (rolActual != "Investigador")
    {
        <a href="@Url.Action("Agregar", "Eventos")" class="btn btn-success fw-bold shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Agregar Evento
        </a>
    }
</div>

<div class="card bg-light border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form action="@Url.Action("Index", "Eventos")" method="get" id="formBusqueda">
            <div class="row g-2 align-items-center">
                <div class="col-12 col-md-auto">
                    <span class="fw-bold text-secondary mb-0"><i class="bi bi-funnel me-1"></i> Consultar por parámetros:</span>
                </div>

                <div class="col-12 col-md-3">
                    <select class="form-select border-info" id="selectFiltro" name="tipoFiltro">
                        <option value="">Seleccione filtro...</option>
                        <option value="idEvento">ID Evento</option>
                        <option value="nombreEvento">Nombre Evento</option>
                        <option value="tipoEvento">Tipo de Evento</option>
                        <option value="lugarEvento">Lugar / Ubicación</option>
                        <option value="organizadorEvento">Organizador</option>
                    </select>
                </div>

                <div class="col-12 col-md" id="contenedorInput">
                    <input type="text" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="Seleccione un filtro primero..." disabled>
                </div>

                <datalist id="opcionesSugeridas"></datalist>

                <div class="col-12 col-md-auto">
                    <button type="submit" class="btn btn-info text-white fw-bold px-4 w-100" id="btnConsultar" disabled>
                        <i class="bi bi-search"></i> Consultar
                    </button>
                </div>

                @if (Request.QueryString["tipoFiltro"] != null)
                {
                    <div class="col-12 col-md-auto">
                        <a href="@Url.Action("Index", "Eventos")" class="btn btn-secondary fw-bold w-100">
                            <i class="bi bi-arrow-clockwise"></i> Limpiar
                        </a>
                    </div>
                }
            </div>
        </form>
    </div>
</div>

<div class="table-responsive shadow-sm rounded-3 border">
    <table class="table table-hover table-striped mb-0 align-middle" id="tablaEventos">
        <thead class="table-dark">
            <tr>
                <th scope="col" class="py-3 ps-3">ID</th>
                <th scope="col" class="py-3">Nombre del Evento</th>
                <th scope="col" class="py-3">Tipo / Modalidad</th>
                <th scope="col" class="py-3">Fecha y Hora</th>
                <th scope="col" class="py-3">Proyectos Vinculados</th>
                <th scope="col" class="py-3">Patrocinadores</th>
                <th scope="col" class="py-3 text-center" style="min-width: 140px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var evento in Model)
                {
                    <tr>
                        <td class="ps-3 fw-medium data-idEvento">@evento.IdEvento</td>
                        <td>
                            <span class="fw-bold text-primary data-nombreEvento">@evento.NombreEvento</span>

                            @{
                                string colorEstado = "bg-primary";
                                if (evento.Estado == "En curso") { colorEstado = "bg-success"; }
                                else if (evento.Estado == "Borrador") { colorEstado = "bg-secondary"; }
                                else if (evento.Estado == "Cancelado") { colorEstado = "bg-danger"; }
                            }
                            <span class="badge @colorEstado ms-1" style="font-size: 0.7rem;">@(string.IsNullOrEmpty(evento.Estado) ? "Programado" : evento.Estado)</span>
                            <br />

                            <small class="text-muted"><i class="bi bi-person border-end pe-1 me-1"></i>Org: <span class="data-organizadorEvento">@evento.OrganizadorEvento</span></small>
                        </td>
                        <td>
                            <span class="badge bg-info text-white mb-1 data-tipoEvento">@evento.TipoEvento</span>

                            @if (evento.Modalidad == "Virtual")
                            {
                                <span class="badge bg-dark text-white mb-1 ms-1"><i class="bi bi-laptop"></i> Virtual</span>
                            }
                            else if (evento.Modalidad == "Híbrido")
                            {
                                <span class="badge bg-dark text-white mb-1 ms-1"><i class="bi bi-building"></i>+<i class="bi bi-laptop"></i> Híbrido</span>
                            }
                            <br />

                            <small class="text-dark fw-semibold data-lugarEvento"><i class="bi bi-geo-alt-fill text-danger"></i> @evento.LugarEvento</small>
                        </td>
                        <td class="fw-medium text-secondary">
                            <div class="mb-1">
                                <i class="bi bi-calendar3 text-primary"></i>
                                @String.Format("{0:dd/MM/yyyy}", evento.FechaEvento)
                            </div>

                            @if (!string.IsNullOrEmpty(evento.HoraInicio) && !string.IsNullOrEmpty(evento.HoraFin))
                            {
                                <small class="text-muted fw-normal"><i class="bi bi-clock text-info"></i> @evento.HoraInicio - @evento.HoraFin</small>
                            }
                        </td>

                        <td>
                            @if (evento.ProyectosParticipantes != null && evento.ProyectosParticipantes.Any())
                            {
                                <div class="d-flex flex-column gap-1">
                                    @foreach (var p in evento.ProyectosParticipantes)
                                    {
                                        <span class="badge bg-secondary text-start text-wrap" style="max-width: 200px;" title="ID Proyecto: @p.IdProyecto">
                                            <i class="bi bi-file-earmark-text"></i> @p.TituloProyecto
                                        </span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">Sin proyectos</span>
                            }
                        </td>

                        <td>
                            @if (evento.Patrocinadores != null && evento.Patrocinadores.Any())
                            {
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var pat in evento.Patrocinadores)
                                    {
                                        <span class="badge bg-light text-dark border border-success px-2 py-1" title="@pat.CorreoPatrocinador">
                                            <i class="bi bi-cash-coin text-success"></i> @pat.NombrePatrocinador
                                        </span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">Sin patrocinio</span>
                            }
                        </td>

                        <td class="text-center">
                            <a href="@Url.Action("Detalle", "Eventos", new { id = evento.IdEvento })" class="btn btn-sm btn-outline-info me-1" title="Ver Detalles y Agenda">
                                <i class="bi bi-eye-fill"></i>
                            </a>

                            @if (rolActual != "Investigador")
                            {
                                <a href="@Url.Action("Modificar", "Eventos", new { id = evento.IdEvento })" class="btn btn-sm btn-outline-primary me-1" title="Editar">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmarEliminacion(@evento.IdEvento)" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center py-4 text-muted">
                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                        No se encontraron eventos registrados o que coincidan con los filtros.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        const datosAutocompletado = {
            idEvento: [...new Set(Array.from(document.querySelectorAll('.data-idEvento')).map(el => el.textContent.trim()))],
            nombreEvento: [...new Set(Array.from(document.querySelectorAll('.data-nombreEvento')).map(el => el.textContent.trim()))],
            tipoEvento: [...new Set(Array.from(document.querySelectorAll('.data-tipoEvento')).map(el => el.textContent.trim()))],
            lugarEvento: [...new Set(Array.from(document.querySelectorAll('.data-lugarEvento')).map(el => el.textContent.trim()))],
            organizadorEvento: [...new Set(Array.from(document.querySelectorAll('.data-organizadorEvento')).map(el => el.textContent.trim()))]
        };

        const selectFiltro = document.getElementById('selectFiltro');
        const contenedorInput = document.getElementById('contenedorInput');
        const btnConsultar = document.getElementById('btnConsultar');
        const datalist = document.getElementById('opcionesSugeridas');

        selectFiltro.addEventListener('change', function () {
            const filtroSeleccionado = this.value;
            datalist.innerHTML = '';

            if (!filtroSeleccionado) {
                contenedorInput.innerHTML = '<input type="text" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="Seleccione un filtro primero..." disabled>';
                btnConsultar.disabled = true;
                return;
            }

            btnConsultar.disabled = false;
            let esNumero = (filtroSeleccionado === 'idEvento');
            let tipoInput = esNumero ? 'number' : 'text';
            let placeholder = esNumero ? 'ID exacto del evento...' : 'Escriba parámetros...';

            contenedorInput.innerHTML = `<input type="${tipoInput}" class="form-control border-info" id="inputValor" name="valorFiltro" placeholder="${placeholder}" list="opcionesSugeridas" autocomplete="off" required>`;

            if (datosAutocompletado[filtroSeleccionado]) {
                datosAutocompletado[filtroSeleccionado].forEach(valor => {
                    let option = document.createElement('option');
                    option.value = valor;
                    datalist.appendChild(option);
                });
            }
        });

        document.getElementById('formBusqueda').addEventListener('submit', function (e) {
            const filtro = selectFiltro.value;
            const valor = document.getElementById('inputValor').value.trim();

            if (['idEvento', 'nombreEvento', 'tipoEvento', 'lugarEvento', 'organizadorEvento'].includes(filtro)) {
                if (!datosAutocompletado[filtro].includes(valor)) {
                    e.preventDefault();
                    Swal.fire({ icon: 'error', title: 'Dato de búsqueda incorrecto', text: 'El valor no concuerda con los registros cargados en la tabla.', confirmButtonColor: '#dc3545' });
                }
            }
        });

        // ======= CORRECCIÓN DE MENSAJES (COMILLAS) =======
        var mensajeExito = '@Html.Raw(TempData["Exito"] != null ? HttpUtility.JavaScriptStringEncode(TempData["Exito"].ToString()) : "")';
        if (mensajeExito) { Swal.fire({ icon: 'success', title: '¡Completado!', text: mensajeExito, confirmButtonColor: '#0284c7' }); }

        var mensajeError = '@Html.Raw(TempData["Error"] != null ? HttpUtility.JavaScriptStringEncode(TempData["Error"].ToString()) : "")';
        if (mensajeError) { Swal.fire({ icon: 'error', title: 'Error', text: mensajeError, confirmButtonColor: '#dc3545' }); }
        // =================================================

        function confirmarEliminacion(id) {
            Swal.fire({
                title: '¿Eliminar este evento?',
                text: "Esta acción no alterará los proyectos de manera independiente, pero removerá el registro del evento.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, borrar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = '@Url.Action("Eliminar", "Eventos")?id=' + id;
                }
            });
        }
    </script>
}