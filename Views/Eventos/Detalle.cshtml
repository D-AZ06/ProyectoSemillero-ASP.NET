@model ProyectoSemillero_ASP.NET.Models.DatosEvento

@{
    ViewBag.Title = "Detalle del Evento";
}

<div class="container-fluid max-width-800 py-4">
    <div class="d-flex align-items-center mb-3">
        <a href="@Url.Action("Index", "Eventos")" class="btn btn-outline-secondary btn-sm me-3">
            <i class="bi bi-arrow-left"></i> Volver al Listado
        </a>
        <h3 class="fw-bold text-dark mb-0">Información del Evento</h3>
    </div>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
        <div class="card-header bg-dark text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-info-circle me-2"></i> @Model.NombreEvento</h5>
        </div>
        <div class="card-body p-4">
            <div class="row mb-3">
                <div class="col-sm-4 fw-bold text-secondary">Tipo de Evento:</div>
                <div class="col-sm-8 text-dark">@Model.TipoEvento</div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4 fw-bold text-secondary">Fecha de Realización:</div>
                <div class="col-sm-8 text-dark"><i class="bi bi-calendar-event text-primary"></i> @Model.FechaEvento</div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4 fw-bold text-secondary">Lugar / Espacio:</div>
                <div class="col-sm-8 text-dark fw-bold text-danger"><i class="bi bi-geo-alt-fill"></i> @Model.LugarEvento</div>
            </div>
            <div class="row mb-3">
                <div class="col-sm-4 fw-bold text-secondary">Organizado por:</div>
                <div class="col-sm-8 text-dark">@Model.OrganizadorEvento</div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="card shadow-sm h-100 border-start border-primary border-4">
                <div class="card-body">
                    <h5 class="fw-bold text-primary"><i class="bi bi-journal-code"></i> Proyectos Presentados</h5>
                    <ul class="list-group list-group-flush mt-3">
                        @if (Model.ProyectosParticipantes != null && Model.ProyectosParticipantes.Any())
                        {
                            foreach (var p in Model.ProyectosParticipantes)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>@p.TituloProyecto</span>
                                    <span class="badge bg-primary rounded-pill">ID: @p.IdProyecto</span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-muted small">No hay proyectos inscritos en este evento.</li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card shadow-sm h-100 border-start border-success border-4">
                <div class="card-body">
                    <h5 class="fw-bold text-success"><i class="bi bi-award"></i> Alianzas y Patrocinios</h5>
                    <div class="mt-3">
                        @if (Model.Patrocinadores != null && Model.Patrocinadores.Any())
                        {
                            foreach (var pat in Model.Patrocinadores)
                            {
                                <div class="p-2 border-bottom">
                                    <div class="fw-bold text-dark">@pat.NombrePatrocinador</div>
                                    <small class="text-muted d-block">Tipo: @pat.TipoPatrocinador</small>
                                    <small class="text-muted d-block"><i class="bi bi-envelope"></i> @pat.CorreoPatrocinador</small>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted small px-2">Este evento no cuenta con patrocinadores asignados.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>