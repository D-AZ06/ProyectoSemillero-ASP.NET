        const hoy = new Date();
        const yyyy = hoy.getFullYear();
        const mm = String(hoy.getMonth() + 1).padStart(2, '0');
        const dd = String(hoy.getDate()).padStart(2, '0');
        const fechaMinima = `${yyyy}-${mm}-${dd}`;

        // Lógica para bloquear el calendario visualmente
        let limiteMinimoVisual = fechaMinima;
        if (fechaOriginal && fechaOriginal < fechaMinima) {
            limiteMinimoVisual = fechaOriginal;
        }
        inputFecha.setAttribute('min', limiteMinimoVisual);

        inputFecha.addEventListener('change', function() {
            if(this.value && this.value < fechaMinima && this.value !== fechaOriginal) {
                this.classList.add('border-danger');
                errorFecha.classList.remove('d-none');
                this.value = fechaOriginal;
            } else {
                this.classList.remove('border-danger');
                errorFecha.classList.add('d-none');
            }
        });

        const selectSemillero = document.getElementById('IdSemillero');
        const contenedorProyectos = document.getElementById('contenedorProyectos');

        const proyectosDisponibles = [
            @if(ViewBag.ListaProyectos != null) {
                foreach(var p in (List<ProyectoSemillero_ASP.NET.Models.DatosProyecto>)ViewBag.ListaProyectos) {
                    @Html.Raw($"{{ id: '{p.IdProyecto}', titulo: '{HttpUtility.JavaScriptStringEncode(p.TituloProyecto)}', semillero: '{p.IdSemillero}' }},")
                }
            }
        ];

        const proyectosYaVinculados = [
            @if(Model.ProyectosParticipantes != null) {
                foreach(var pp in Model.ProyectosParticipantes) {
                    @Html.Raw($"'{pp.IdProyecto}',")
                }
            }
        ];

        function actualizarProyectos() {
            if(!selectSemillero) return;
            const semilleroSeleccionado = selectSemillero.value;
            contenedorProyectos.innerHTML = '';

            if(!semilleroSeleccionado) {
                contenedorProyectos.innerHTML = '<div class="text-muted small p-2">-- Seleccione un semillero primero --</div>';
                return;
            }

            const filtrados = proyectosDisponibles.filter(p => p.semillero === semilleroSeleccionado);

            if(filtrados.length === 0) {
                contenedorProyectos.innerHTML = '<div class="text-muted small p-2">No hay proyectos registrados en este semillero.</div>';
            } else {
                filtrados.forEach(p => {
                    const isSelected = proyectosYaVinculados.includes(p.id) ? 'checked' : '';
                    const chkHTML = `
                        <div class="form-check mb-1">
                            <input class="form-check-input border-primary" type="checkbox" name="proyectosSeleccionados" value="${p.id}" id="proy_${p.id}" ${isSelected}>
                            <label class="form-check-label text-dark fw-medium" for="proy_${p.id}" style="cursor: pointer;">
                                ID: ${p.id} - ${p.titulo}
                            </label>
                        </div>
                    `;
                    contenedorProyectos.insertAdjacentHTML('beforeend', chkHTML);
                });
            }
        }

        if(selectSemillero) {
            selectSemillero.addEventListener('change', actualizarProyectos);
            actualizarProyectos();
        }

        const diccionarios = {
            nombres: [ @if(ViewBag.NombresSugeridos != null) { foreach(var n in ViewBag.NombresSugeridos) { @Html.Raw($"\"{HttpUtility.JavaScriptStringEncode(n)}\",") } } ],
            tipos: [ @if(ViewBag.TiposSugeridos != null) { foreach(var t in ViewBag.TiposSugeridos) { @Html.Raw($"\"{HttpUtility.JavaScriptStringEncode(t)}\",") } } ],
            lugares: [ @if(ViewBag.LugaresSugeridos != null) { foreach(var l in ViewBag.LugaresSugeridos) { @Html.Raw($"\"{HttpUtility.JavaScriptStringEncode(l)}\",") } } ],
            organizadores: [ @if(ViewBag.OrganizadoresSugeridos != null) { foreach(var o in ViewBag.OrganizadoresSugeridos) { @Html.Raw($"\"{HttpUtility.JavaScriptStringEncode(o)}\",") } } ]
        };

        function normalizar(texto) {
            return texto ? texto.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase().trim() : "";
        }

        document.querySelectorAll('.autocompletar').forEach(input => {
            input.addEventListener('blur', function() {
                const valorIngresado = normalizar(this.value);
                if (!valorIngresado) return;

                const tipoDiccionario = this.getAttribute('data-tipo');
                const lista = diccionarios[tipoDiccionario];

                const coincidencia = lista.find(item => normalizar(item) === valorIngresado);

                if (coincidencia && coincidencia !== this.value.trim()) {
                    this.value = coincidencia;
                    Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 }).fire({
                        icon: 'info', title: 'Estandarizado', text: `Auto-corregido a "${coincidencia}"`
                    });
                }
            });
        });

        document.getElementById('formModificarEvento').addEventListener('submit', function (e) {
            if(!inputFecha.value || (inputFecha.value < fechaMinima && inputFecha.value !== fechaOriginal)) {
                e.preventDefault();
                inputFecha.focus();
                return;
            }

            const proyectosSeleccionados = document.querySelectorAll('input[name="proyectosSeleccionados"]:checked');
            if (proyectosSeleccionados.length === 0) {
                e.preventDefault();
                Swal.fire({
                    icon: 'warning',
                    title: 'Proyectos Requeridos',
                    text: 'Es obligatorio mantener al menos un proyecto participante para este evento.',
                    confirmButtonColor: '#ffc107'
                });
                return;
            }

            const btn = document.getElementById('btnGuardarEvento');
            setTimeout(() => {
                btn.disabled = true;
                btn.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Actualizando...`;
            }, 10);
        });
    </script>
}