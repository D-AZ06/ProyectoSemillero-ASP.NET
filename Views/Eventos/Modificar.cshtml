@model ProyectoSemillero_ASP.NET.Models.DatosEvento

@{
    ViewBag.Title = "Editar Evento";
    Layout = "~/Views/Shared/_LayoutSimple.cshtml";
    string rolUsuario = ViewBag.RolUsuario as string;
}

<style>
    body > .container {
        display: block !important;
        padding-top: 2rem !important;
    }

    .caja-scroll::-webkit-scrollbar {
        width: 6px;
    }

    .caja-scroll::-webkit-scrollbar-thumb {
        background-color: #cbd5e1;
        border-radius: 4px;
    }
</style>

<div class="w-100 text-start mb-5" style="max-width: 850px; margin: 0 auto;">

    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h3 class="fw-bold text-dark mb-0">
            <i class="bi bi-pencil-square text-primary me-2"></i> Editar Evento Existente
        </h3>

        <a href="@Url.Action("Index", "Eventos")" class="btn btn-outline-secondary fw-bold shadow-sm">
            <i class="bi bi-arrow-left"></i> Cancelar y Volver
        </a>
    </div>

    <div class="card shadow-sm border-0 bg-white">
        <div class="card-body p-4">
            @using (Html.BeginForm("Modificar", "Eventos", FormMethod.Post, new { id = "formModificarEvento" }))
            {
                @Html.AntiForgeryToken()

                @Html.HiddenFor(m => m.Id)

                <div class="mb-4 bg-light p-3 rounded-3 border border-primary-subtle">
                    <label class="form-label fw-bold text-primary mb-1">
                        <i class="bi bi-hash me-1"></i> ID Evento
                    </label>
                    @Html.TextBoxFor(m => m.IdEvento, new { @class = "form-control bg-white text-muted fw-semibold", @type = "number", @readonly = "readonly" })
                    <small class="text-muted"><i class="bi bi-info-circle-fill text-info mt-2"></i> Este identificador no se puede alterar.</small>
                </div>

                <div class="row">
                    <div class="col-md-7 mb-3">
                        <label class="form-label fw-bold text-secondary">
                            <i class="bi bi-card-text me-1"></i> Nombre del Evento
                        </label>
                        @Html.TextBoxFor(m => m.NombreEvento, new { @class = "form-control border-secondary-subtle autocompletar", @required = "required", @list = "listaNombres", autocomplete = "off", data_tipo = "nombres" })
                        <datalist id="listaNombres">
                            @if (ViewBag.NombresSugeridos != null)
                            {
                                foreach (var item in ViewBag.NombresSugeridos)
                                {
                                    <option value="@item"></option>
                                }
                            }
                        </datalist>
                    </div>
                    <div class="col-md-5 mb-3">
                        <label class="form-label fw-bold text-secondary">
                            <i class="bi bi-tags-fill me-1"></i> Tipo de Evento
                        </label>
                        @Html.TextBoxFor(m => m.TipoEvento, new { @class = "form-control border-secondary-subtle autocompletar", @required = "required", @list = "listaTipos", autocomplete = "off", data_tipo = "tipos" })
                        <datalist id="listaTipos">
                            @if (ViewBag.TiposSugeridos != null)
                            {
                                foreach (var item in ViewBag.TiposSugeridos)
                                {
                                    <option value="@item"></option>
                                }
                            }
                        </datalist>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-5 mb-3">
                        <label class="form-label fw-bold text-secondary">
                            <i class="bi bi-calendar-event-fill me-1"></i> Fecha de Celebración
                        </label>
                        @Html.TextBoxFor(m => m.FechaEvento, new { @class = "form-control border-secondary-subtle", @type = "date", @required = "required", id = "FechaEvento", data_fecha_original = Model.FechaEvento })
                        <small class="text-danger fw-semibold d-none" id="errorFecha">No puedes modificarla a una nueva fecha en el pasado.</small>
                    </div>
                    <div class="col-md-7 mb-3">
                        <label class="form-label fw-bold text-secondary">
                            <i class="bi bi-geo-alt-fill me-1"></i> Lugar / Ubicación
                        </label>
                        @Html.TextBoxFor(m => m.LugarEvento, new { @class = "form-control border-secondary-subtle autocompletar", @required = "required", @list = "listaLugares", autocomplete = "off", data_tipo = "lugares" })
                        <datalist id="listaLugares">
                            @if (ViewBag.LugaresSugeridos != null)
                            {
                                foreach (var item in ViewBag.LugaresSugeridos)
                                {
                                    <option value="@item"></option>
                                }
                            }
                        </datalist>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold text-secondary">
                            <i class="bi bi-person-badge-fill me-1"></i> Organizador Principal
                        </label>
                        @Html.TextBoxFor(m => m.OrganizadorEvento, new { @class = "form-control border-secondary-subtle autocompletar", @required = "required", @list = "listaOrganizadores", autocomplete = "off", data_tipo = "organizadores" })
                        <datalist id="listaOrganizadores">
                            @if (ViewBag.OrganizadoresSugeridos != null)
                            {
                                foreach (var item in ViewBag.OrganizadoresSugeridos)
                                {
                                    <option value="@item"></option>
                                }
                            }
                        </datalist>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold text-secondary">
                            <i class="bi bi-diagram-3-fill me-1"></i> Semillero Vinculado
                        </label>
                        @if (rolUsuario == "Líder")
                        {
                            <input type="text" class="form-control bg-light border-secondary-subtle text-muted" value="@ViewBag.NombreSemilleroFijo" readonly />
                            <input type="hidden" name="IdSemillero" id="IdSemillero" value="@ViewBag.IdSemilleroFijo" />
                        }
                        else
                        {
                            @Html.DropDownListFor(m => m.IdSemillero, ViewBag.ListaSemilleros as SelectList, "-- Seleccione un Semillero --", new { @class = "form-select border-secondary-subtle fw-medium", @required = "required", id = "IdSemillero" })
                        }
                    </div>
                </div>

                <hr class="text-muted my-4" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold text-dark">
                            <i class="bi bi-journal-code text-primary me-1"></i> Proyectos Participantes <span class="text-danger">*</span>
                        </label>
                        <p class="text-muted small mb-2">Marca las casillas para modificar los proyectos vinculados.</p>

                        <div id="contenedorProyectos" class="caja-scroll border border-primary-subtle rounded-3 p-2 bg-white shadow-sm" style="height: 140px; overflow-y: auto;">
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold text-dark">
                            <i class="bi bi-award text-info me-1"></i> Patrocinadores Asignados
                        </label>
                        <p class="text-muted small mb-2">Marca las entidades que respaldan económicamente este evento.</p>

                        <div class="caja-scroll border border-info-subtle rounded-3 p-2 bg-white shadow-sm" style="height: 140px; overflow-y: auto;">
                            @if (ViewBag.CatalogoPatrocinadores != null)
                            {
                                var patrocActuales = Model.Patrocinadores?.Select(p => p.IdPatrocinador).ToList() ?? new List<int>();
                                foreach (var pat in (List<ProyectoSemillero_ASP.NET.Models.DatosPatrocinador>)ViewBag.CatalogoPatrocinadores)
                                {
                                    bool isSelected = patrocActuales.Contains(pat.IdPatrocinador);
                                    <div class="form-check mb-1">
                                        <input class="form-check-input border-info" type="checkbox" name="patrocinadoresSeleccionados" value="@pat.IdPatrocinador" id="pat_@pat.IdPatrocinador" @(isSelected ? "checked" : "")>
                                        <label class="form-check-label text-dark fw-medium" for="pat_@pat.IdPatrocinador" style="cursor: pointer;">
                                            @pat.NombrePatrocinador <span class="text-muted small">(@pat.TipoPatrocinador)</span>
                                        </label>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-muted small">No hay patrocinadores registrados en el catálogo.</div>
                            }
                        </div>
                    </div>
                </div>

                <div class="mt-4 text-end">
                    <button type="submit" class="btn btn-success fw-bold px-4 shadow-sm" id="btnGuardarEvento">
                        <i class="bi bi-arrow-repeat me-1"></i> Guardar Cambios
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var mensajeError = '@TempData["Error"]';
        if (mensajeError) {
            Swal.fire({ icon: 'error', title: 'Error', text: mensajeError, confirmButtonColor: '#dc3545' });
        }

        const inputFecha = document.getElementById('FechaEvento');
        const errorFecha = document.getElementById('errorFecha');
        const fechaOriginal = inputFecha.getAttribute('data-fecha-original');

        const hoy = new Date();
        const yyyy = hoy.getFullYear();
        const mm = String(hoy.getMonth() + 1).padStart(2, '0');
        const dd = String(hoy.getDate()).padStart(2, '0');
        const fechaMinima = `${yyyy}-${mm}-${dd}`;

        // Lógica para bloquear el calendario visualmente
        let limiteMinimoVisual = fechaMinima;
        if (fechaOriginal && fechaOriginal < fechaMinima) {
            limiteMinimoVisual = fechaOriginal;
        }
        inputFecha.setAttribute('min', limiteMinimoVisual);

        inputFecha.addEventListener('change', function() {
            if(this.value && this.value < fechaMinima && this.value !== fechaOriginal) {
                this.classList.add('border-danger');
                errorFecha.classList.remove('d-none');
                this.value = fechaOriginal;
            } else {
                this.classList.remove('border-danger');
                errorFecha.classList.add('d-none');
            }
        });

        const selectSemillero = document.getElementById('IdSemillero');
        const contenedorProyectos = document.getElementById('contenedorProyectos');

        const proyectosDisponibles = [
            @if(ViewBag.ListaProyectos != null) {
                foreach(var p in (List<ProyectoSemillero_ASP.NET.Models.DatosProyecto>)ViewBag.ListaProyectos) {
                    @Html.Raw($"{{ id: '{p.IdProyecto}', titulo: '{HttpUtility.JavaScriptStringEncode(p.TituloProyecto)}', semillero: '{p.IdSemillero}' }},")
                }
            }
        ];

        const proyectosYaVinculados = [
            @if(Model.ProyectosParticipantes != null) {
                foreach(var pp in Model.ProyectosParticipantes) {
                    @Html.Raw($"'{pp.IdProyecto}',")
                }
            }
        ];

        function actualizarProyectos() {
            if(!selectSemillero) return;
            const semilleroSeleccionado = selectSemillero.value;
            contenedorProyectos.innerHTML = '';

            if(!semilleroSeleccionado) {
                contenedorProyectos.innerHTML = '<div class="text-muted small p-2">-- Seleccione un semillero primero --</div>';
                return;
            }

            const filtrados = proyectosDisponibles.filter(p => p.semillero === semilleroSeleccionado);

            if(filtrados.length === 0) {
                contenedorProyectos.innerHTML = '<div class="text-muted small p-2">No hay proyectos registrados en este semillero.</div>';
            } else {
                filtrados.forEach(p => {
                    const isSelected = proyectosYaVinculados.includes(p.id) ? 'checked' : '';
                    const chkHTML = `
                        <div class="form-check mb-1">
                            <input class="form-check-input border-primary" type="checkbox" name="proyectosSeleccionados" value="${p.id}" id="proy_${p.id}" ${isSelected}>
                            <label class="form-check-label text-dark fw-medium" for="proy_${p.id}" style="cursor: pointer;">
                                ID: ${p.id} - ${p.titulo}
                            </label>
                        </div>
                    `;
                    contenedorProyectos.insertAdjacentHTML('beforeend', chkHTML);
                });
            }
        }

        if(selectSemillero) {
            selectSemillero.addEventListener('change', actualizarProyectos);
            actualizarProyectos();
        }

        const diccionarios = {
            nombres: [ @if(ViewBag.NombresSugeridos != null) { foreach(var n in ViewBag.NombresSugeridos) { @Html.Raw($"\"{HttpUtility.JavaScriptStringEncode(n)}\",") } } ],
            tipos: [ @if(ViewBag.TiposSugeridos != null) { foreach(var t in ViewBag.TiposSugeridos) { @Html.Raw($"\"{HttpUtility.JavaScriptStringEncode(t)}\",") } } ],
            lugares: [ @if(ViewBag.LugaresSugeridos != null) { foreach(var l in ViewBag.LugaresSugeridos) { @Html.Raw($"\"{HttpUtility.JavaScriptStringEncode(l)}\",") } } ],
            organizadores: [ @if(ViewBag.OrganizadoresSugeridos != null) { foreach(var o in ViewBag.OrganizadoresSugeridos) { @Html.Raw($"\"{HttpUtility.JavaScriptStringEncode(o)}\",") } } ]
        };

        function normalizar(texto) {
            return texto ? texto.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase().trim() : "";
        }

        document.querySelectorAll('.autocompletar').forEach(input => {
            input.addEventListener('blur', function() {
                const valorIngresado = normalizar(this.value);
                if (!valorIngresado) return;

                const tipoDiccionario = this.getAttribute('data-tipo');
                const lista = diccionarios[tipoDiccionario];

                const coincidencia = lista.find(item => normalizar(item) === valorIngresado);

                if (coincidencia && coincidencia !== this.value.trim()) {
                    this.value = coincidencia;
                    Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 3000 }).fire({
                        icon: 'info', title: 'Estandarizado', text: `Auto-corregido a "${coincidencia}"`
                    });
                }
            });
        });

        document.getElementById('formModificarEvento').addEventListener('submit', function (e) {
            if(!inputFecha.value || (inputFecha.value < fechaMinima && inputFecha.value !== fechaOriginal)) {
                e.preventDefault();
                inputFecha.focus();
                return;
            }

            const proyectosSeleccionados = document.querySelectorAll('input[name="proyectosSeleccionados"]:checked');
            if (proyectosSeleccionados.length === 0) {
                e.preventDefault();
                Swal.fire({
                    icon: 'warning',
                    title: 'Proyectos Requeridos',
                    text: 'Es obligatorio mantener al menos un proyecto participante para este evento.',
                    confirmButtonColor: '#ffc107'
                });
                return;
            }

            const btn = document.getElementById('btnGuardarEvento');
            setTimeout(() => {
                btn.disabled = true;
                btn.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Actualizando...`;
            }, 10);
        });
    </script>
